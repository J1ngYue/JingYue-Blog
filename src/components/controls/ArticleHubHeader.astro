---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

interface Props {
	active: "archive" | "categories" | "tags";
}

const { active } = Astro.props;
const tabs = [
	{
		key: "archive",
		label: "文章归档",
		description: "按时间浏览全部文章",
		href: url("/archive/#main-content-wrapper"),
		icon: "material-symbols:archive-rounded",
	},
	{
		key: "categories",
		label: "文章分类",
		description: "按主题快速定位内容",
		href: url("/categories/#main-content-wrapper"),
		icon: "material-symbols:folder-open-rounded",
	},
	{
		key: "tags",
		label: "文章标签",
		description: "从关键词探索文章",
		href: url("/tags/#main-content-wrapper"),
		icon: "material-symbols:tag-rounded",
	},
] as const;
---

<header class="article-hub-header card-base onload-animation mb-4" aria-labelledby="article-hub-title">
	<div class="article-hub-copy">
		<p class="article-hub-kicker">JINGYUE · ARTICLE SPACE</p>
		<h1 id="article-hub-title">文章中心</h1>
		<p>归档、分类与标签都收在这里，选择一种方式开始阅读。</p>
	</div>

	<nav class="article-hub-tabs" aria-label="文章浏览方式">
		{tabs.map((tab) => (
			<a
				href={tab.href}
				class:list={["article-hub-tab", { "is-active": active === tab.key }]}
				aria-current={active === tab.key ? "page" : undefined}
			>
				<span class="article-hub-tab-icon" aria-hidden="true">
					<Icon is:inline name={tab.icon} />
				</span>
				<span>
					<strong>{tab.label}</strong>
					<small>{tab.description}</small>
				</span>
			</a>
		))}
	</nav>
</header>

<style>
	.article-hub-header {
		display: grid;
		grid-template-columns: minmax(13rem, 0.72fr) minmax(0, 1.28fr);
		gap: clamp(1rem, 3vw, 2.5rem);
		padding: clamp(1.25rem, 3vw, 2.25rem);
		border: 1px solid color-mix(in oklch, var(--primary) 22%, var(--line-divider));
		background:
			radial-gradient(circle at 8% 10%, color-mix(in oklch, var(--primary) 12%, transparent), transparent 32%),
			var(--card-bg);
	}

	.article-hub-copy {
		display: flex;
		min-width: 0;
		flex-direction: column;
		justify-content: center;
	}

	.article-hub-kicker {
		margin: 0 0 0.5rem;
		color: var(--primary);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.2em;
	}

	.article-hub-copy h1 {
		margin: 0;
		color: var(--text-90);
		font-size: clamp(1.65rem, 3vw, 2.6rem);
		line-height: 1.05;
	}

	.article-hub-copy > p:last-child {
		margin: 0.75rem 0 0;
		color: var(--text-50);
		font-size: 0.92rem;
		line-height: 1.7;
	}

	.article-hub-tabs {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		align-items: stretch;
	}

	.article-hub-tab {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: 0.7rem;
		padding: 1rem 0.9rem;
		border: 1px solid color-mix(in oklch, var(--line-divider) 78%, transparent);
		border-radius: 1rem;
		background: color-mix(in oklch, var(--card-bg) 78%, transparent);
		color: var(--text-75);
		transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
	}

	.article-hub-tab:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklch, var(--primary) 45%, var(--line-divider));
	}

	.article-hub-tab.is-active {
		border-color: color-mix(in oklch, var(--primary) 50%, transparent);
		background: color-mix(in oklch, var(--primary) 13%, var(--card-bg));
		color: var(--primary);
		box-shadow: 0 0.8rem 2rem color-mix(in oklch, var(--primary) 10%, transparent);
	}

	.article-hub-tab-icon {
		display: grid;
		width: 2.5rem;
		height: 2.5rem;
		flex: 0 0 auto;
		place-items: center;
		border-radius: 0.8rem;
		background: color-mix(in oklch, var(--primary) 10%, var(--btn-regular-bg));
		color: var(--primary);
	}

	.article-hub-tab-icon :global(svg) {
		width: 1.25rem;
		height: 1.25rem;
	}

	.article-hub-tab strong,
	.article-hub-tab small {
		display: block;
	}

	.article-hub-tab strong {
		font-size: 0.9rem;
	}

	.article-hub-tab small {
		margin-top: 0.25rem;
		overflow: hidden;
		color: var(--text-30);
		font-size: 0.7rem;
		line-height: 1.35;
		text-overflow: ellipsis;
	}

	@media (max-width: 900px) {
		.article-hub-header {
			grid-template-columns: minmax(0, 1fr);
		}
	}

	@media (max-width: 600px) {
		.article-hub-tabs {
			grid-template-columns: minmax(0, 1fr);
		}

		.article-hub-tab {
			padding: 0.78rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.article-hub-tab {
			transition: none;
		}
	}
</style>
