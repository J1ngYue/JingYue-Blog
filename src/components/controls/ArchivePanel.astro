---
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getSortedPostsList } from "@/utils/content-utils";
import { getPostUrlBySlug, url } from "@/utils/url-utils";

// 归档列表：全量按年分组，服务端渲染。筛选（?tag=/?category=/?uncategorized）
// 与年份折叠由客户端脚本处理——数据本身在构建期已全部就绪。
const sortedPostsList = await getSortedPostsList();

// 严格按发布时间倒序（不受置顶影响），镜像原 Svelte 版行为
const posts = sortedPostsList
	.slice()
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// 按年份分组
const grouped = new Map<number, typeof posts>();
for (const post of posts) {
	const year = post.data.published.getFullYear();
	if (!grouped.has(year)) grouped.set(year, []);
	grouped.get(year)?.push(post);
}
const groups = Array.from(grouped.entries())
	.map(([year, yearPosts]) => ({ year, posts: yearPosts }))
	.sort((a, b) => b.year - a.year);

// 初始折叠规则：foldArticle 非 false 且多于一年时，除首年外全部折叠
const foldArticle = siteConfig.foldArticle !== false;
const collapseAllButFirst = foldArticle && groups.length > 1;

function formatDate(date: Date) {
	const month = (date.getMonth() + 1).toString().padStart(2, "0");
	const day = date.getDate().toString().padStart(2, "0");
	return `${month}-${day}`;
}

function formatTag(tagList: string[]) {
	return tagList.map((t) => `#${t}`).join(" ");
}

// 传给客户端脚本的 i18n 文案与配置
const i18nStrings = {
	categories: i18n(I18nKey.categories),
	tags: i18n(I18nKey.tags),
	uncategorized: i18n(I18nKey.uncategorized),
	postCount: i18n(I18nKey.postCount),
	postsCount: i18n(I18nKey.postsCount),
};
const tagsBaseUrl = url("/tags/");
const categoriesBaseUrl = url("/categories/");
const searchBaseUrl = url("/search/");
const foldOnFilter = collapseAllButFirst;
---

<archive-panel
  class="card-base px-8 py-6"
  data-fold={foldOnFilter ? "true" : "false"}
>
  <div class="archive-toolbar mb-5 grid gap-2 md:grid-cols-[minmax(0,1fr)_9rem_auto]">
    <label class="archive-search flex min-w-0 items-center gap-2 rounded-lg border border-(--line-divider) bg-transparent px-3 text-50 transition-colors">
      <svg class="h-4 w-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" stroke-linecap="round" />
      </svg>
      <input
        type="search"
        data-archive-search
        aria-label="搜索文章标题、分类或标签"
        class="h-10 min-w-0 flex-1 border-0 bg-transparent text-sm text-75 outline-none"
        placeholder="搜索文章标题、分类或标签"
        autocomplete="off"
      />
    </label>
    <label class="archive-year-filter relative flex items-center rounded-lg bg-(--btn-regular-bg) text-50">
      <span class="sr-only">按年份筛选</span>
      <select data-archive-year class="h-10 w-full appearance-none border-0 bg-transparent px-3 pr-8 text-sm text-75 outline-none">
        <option value="all">全部年份</option>
        {groups.map((group) => <option value={group.year}>{group.year} 年</option>)}
      </select>
      <svg class="pointer-events-none absolute right-2 h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="m7 10 5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </label>
    <button
      type="button"
      data-archive-reset
      class="btn-regular h-10 rounded-lg px-4 text-sm font-medium"
      hidden
    >
      清除搜索
    </button>
  </div>

  <div class="archive-result-summary mb-4 flex items-center justify-between gap-3 text-xs text-50" aria-live="polite">
    <span data-archive-result-count>共 {posts.length} 篇文章</span>
    <span>可按标题、分类、标签或年份查找</span>
  </div>

  {/* 筛选头部：默认隐藏，客户端在有筛选时填充并显示 */}
  <div id="archive-filter-header" class="mb-5 hidden">
    <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1">
      <div class="min-w-0 text-sm text-75">
        <a id="archive-filter-link" href={tagsBaseUrl} class="text-50 hover:text-(--primary) transition-colors"></a>
        <span class="mx-2 text-30">/</span>
        <span id="archive-filter-values" class="font-semibold text-(--primary)"></span>
        <span id="archive-filter-secondary" class="ml-2 text-50 hidden"></span>
      </div>
      <div class="shrink-0 text-xs text-50">
        <span id="archive-filter-count"></span> <span id="archive-filter-count-label"></span>
      </div>
    </div>
  </div>

  <div data-archive-empty class="archive-empty my-8 rounded-xl border border-dashed border-(--line-divider) px-5 py-10 text-center text-50" hidden>
    没有找到匹配的文章，换一个关键词或年份试试。
  </div>

  {groups.map((group, groupIndex) => {
    const collapsed = collapseAllButFirst && groupIndex > 0;
    return (
      <div class="archive-year-block" data-year={group.year} data-count={group.posts.length}>
        <button
          class="archive-year-toggle flex flex-row w-full items-center h-15 cursor-pointer rounded-lg
                 hover:bg-(--btn-plain-bg-hover) transition-colors group/yr"
          aria-expanded={collapsed ? "false" : "true"}
        >
          <div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75
                      group-hover/yr:text-(--primary)">
            {group.year}
          </div>
          <div class="w-[15%] md:w-[10%]">
            <div class="h-3 w-3 bg-none rounded-full outline-(--primary) mx-auto
                        -outline-offset-2 z-50 outline-3"></div>
          </div>
          <div class="w-[70%] md:w-[80%] transition text-left text-50 flex items-center gap-2
                      group-hover/yr:text-(--primary)">
            <span class="archive-year-count">{group.posts.length}</span>
            {" "}
            <span class="archive-year-count-label">{i18n(group.posts.length === 1 ? I18nKey.postCount : I18nKey.postsCount)}</span>
            <span class="archive-arrow" style={collapsed ? "transform: rotate(-90deg)" : ""}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </div>
        </button>

        <div class="archive-year-content" hidden={collapsed}>
          {group.posts.map((post) => (
            <a
              href={getPostUrlBySlug(post.id)}
              aria-label={post.data.title}
              class="archive-post group btn-plain block! h-10 w-full rounded-lg hover:text-[initial]"
              data-tags={JSON.stringify(post.data.tags || [])}
              data-category={post.data.category || ""}
              data-search={`${post.data.title} ${post.data.category || ""} ${(post.data.tags || []).join(" ")} ${post.data.description || ""}`.toLocaleLowerCase()}
            >
              <div class="flex flex-row justify-start items-center h-full">
                {/* date */}
                <div class="w-[15%] md:w-[10%] transition text-sm text-right text-50">
                  {formatDate(post.data.published)}
                </div>

                {/* dot and line */}
                <div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
                  <div class="transition-all mx-auto w-1 h-1 rounded-sm group-hover:h-5
                              bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-(--primary)
                              outline-4 z-50 outline-(--card-bg)
                              group-hover:outline-(--btn-plain-bg-hover)
                              group-active:outline-(--btn-plain-bg-active)"></div>
                </div>

                {/* post title */}
                <div class="w-[70%] md:max-w-[65%] md:w-[65%] text-left font-bold
                            group-hover:translate-x-1 transition-all group-hover:text-(--primary)
                            text-75 pr-8 whitespace-nowrap text-ellipsis overflow-hidden flex items-center gap-2">
                  {post.data.category && (
                    <span class="shrink-0 inline-block text-xs font-medium px-1.5 py-0.5 rounded-sm
                                 bg-[oklch(0.95_0.025_var(--hue))] dark:bg-[oklch(0.25_0.025_var(--hue))]
                                 text-(--primary) group-hover:bg-(--primary) group-hover:text-white!
                                 transition-colors">
                      {post.data.category}
                    </span>
                  )}
                  <span class="truncate">{post.data.title}</span>
                </div>

                {/* tag list */}
                <div class="hidden md:block md:w-[15%] text-left text-sm transition
                            whitespace-nowrap text-ellipsis overflow-hidden text-30">
                  {formatTag(post.data.tags || [])}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    );
  })}
</archive-panel>

<style>
  archive-panel {
    display: block;
    min-height: var(--archive-stable-height, 42rem);
    border: 1px solid color-mix(in oklch, var(--primary) 14%, var(--line-divider));
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--primary) 4%, transparent), transparent 34%),
      var(--card-bg);
    box-shadow: 0 1rem 2.5rem color-mix(in oklch, var(--deep-text) 7%, transparent);
  }
  .archive-toolbar {
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in oklch, var(--line-divider) 72%, transparent);
  }
  .archive-year-block {
    border-top: 1px solid color-mix(in oklch, var(--line-divider) 58%, transparent);
    padding-top: 0.5rem;
  }
  .archive-year-toggle {
    min-height: 3.75rem;
  }
  .archive-post {
    height: 3.5rem !important;
    border-radius: 0.8rem !important;
  }
  .archive-post:hover {
    background: color-mix(in oklch, var(--primary) 7%, transparent);
  }
  .archive-arrow {
    display: inline-flex;
  }
  archive-panel [hidden] {
    display: none !important;
  }
  .archive-toolbar [data-archive-reset][hidden] {
    display: inline-flex !important;
    visibility: hidden;
    pointer-events: none;
  }
  .archive-search input::placeholder {
    color: var(--content-meta);
  }
  .archive-search:focus-within,
  .archive-year-filter:focus-within {
    background: var(--btn-regular-bg-hover);
  }
  .archive-search:focus-within {
    background: transparent;
    border-color: color-mix(in oklch, var(--primary) 44%, var(--line-divider));
    box-shadow: 0 0 0 0.18rem color-mix(in oklch, var(--primary) 10%, transparent);
  }
  @media (max-width: 767px) {
    archive-panel {
      padding-inline: 1rem !important;
    }
    .archive-result-summary > span:last-child {
      display: none;
    }
  }
</style>

<script is:inline define:vars={{ i18nStrings, tagsBaseUrl, categoriesBaseUrl, searchBaseUrl }}>
  class ArchivePanel extends HTMLElement {
    constructor() {
      super();
      // 避免 swup 重复初始化
      if (this.dataset.initialized === "true") return;
      this.dataset.initialized = "true";
      this.init();
      requestAnimationFrame(() => {
        const height = Math.max(
          this.getBoundingClientRect().height,
          window.innerHeight * 0.72,
        );
        this.style.setProperty("--archive-stable-height", `${Math.ceil(height)}px`);
      });
    }

    init() {
      const params = new URLSearchParams(window.location.search);
      const tags = params.has("tag") ? params.getAll("tag") : [];
      const categories = params.has("category") ? params.getAll("category") : [];
      const uncategorized = params.get("uncategorized");
	  this.tags = tags;
	  this.categories = categories;
	  this.uncategorized = !!uncategorized;

      const hasFilter = tags.length > 0 || categories.length > 0 || !!uncategorized;
	  this.bindArchiveTools(params);

      this.applyFilter(tags, categories, !!uncategorized);

	  if (hasFilter) {
        this.updateBannerTitle(tags, categories, !!uncategorized);
      }

      this.bindYearToggles();
    }

	bindArchiveTools(params) {
	  this.searchInput = this.querySelector("[data-archive-search]");
	  this.yearSelect = this.querySelector("[data-archive-year]");
	  this.resetButton = this.querySelector("[data-archive-reset]");
	  if (this.searchInput) this.searchInput.value = params.get("q") || "";
	  if (this.yearSelect) {
		const requestedYear = params.get("year") || "all";
		const exists = Array.from(this.yearSelect.options).some((option) => option.value === requestedYear);
		this.yearSelect.value = exists ? requestedYear : "all";
	  }

	  const refresh = () => {
		this.applyFilter(this.tags, this.categories, this.uncategorized);
		this.updateToolUrl();
	  };
	  this.searchInput?.addEventListener("input", refresh);
	  this.searchInput?.addEventListener("keydown", (event) => {
		if (event.key !== "Enter") return;
		const query = this.searchInput?.value.trim() || "";
		if (!query) return;
		event.preventDefault();
		const target = new URL(searchBaseUrl, window.location.origin);
		target.searchParams.set("q", query);
		if (window.swup?.navigate) window.swup.navigate(target.href);
		else window.location.assign(target.href);
	  });
	  this.yearSelect?.addEventListener("change", refresh);
	  this.resetButton?.addEventListener("click", () => {
		if (this.searchInput) this.searchInput.value = "";
		if (this.yearSelect) this.yearSelect.value = "all";
		refresh();
		this.searchInput?.focus();
	  });
	}

	updateToolUrl() {
	  const current = new URL(window.location.href);
	  const query = this.searchInput?.value.trim() || "";
	  const year = this.yearSelect?.value || "all";
	  if (query) current.searchParams.set("q", query);
	  else current.searchParams.delete("q");
	  if (year !== "all") current.searchParams.set("year", year);
	  else current.searchParams.delete("year");
	  history.replaceState(history.state, "", current);
	}

	normalizeSearchValue(value) {
	  return String(value || "")
		.normalize("NFKD")
		.replace(/\p{Diacritic}/gu, "")
		.toLocaleLowerCase()
		.replace(/\s+/g, " ")
		.trim();
	}

	editDistanceWithin(left, right, limit) {
	  if (Math.abs(left.length - right.length) > limit) return false;
	  let previous = Array.from({ length: right.length + 1 }, (_, index) => index);
	  for (let row = 1; row <= left.length; row++) {
		const current = [row];
		let rowMinimum = current[0];
		for (let column = 1; column <= right.length; column++) {
		  const substitution =
			previous[column - 1] +
			(left[row - 1] === right[column - 1] ? 0 : 1);
		  current[column] = Math.min(
			previous[column] + 1,
			current[column - 1] + 1,
			substitution,
		  );
		  rowMinimum = Math.min(rowMinimum, current[column]);
		}
		if (rowMinimum > limit) return false;
		previous = current;
	  }
	  return previous[right.length] <= limit;
	}

	matchesArchiveQuery(searchValue, rawQuery) {
	  const query = this.normalizeSearchValue(rawQuery);
	  if (!query) return true;
	  const haystack = this.normalizeSearchValue(searchValue);
	  if (haystack.includes(query)) return true;

	  const words = haystack.split(" ").filter(Boolean);
	  return query.split(" ").filter(Boolean).every((token) => {
		if (haystack.includes(token)) return true;
		const limit =
		  token.length >= 4
			? Math.max(1, Math.floor(token.length * 0.35))
			: 0;
		return (
		  limit > 0 &&
		  words.some((word) => this.editDistanceWithin(token, word, limit))
		);
	  });
	}

    // 按筛选条件隐藏不匹配的文章行，重算每年计数，隐藏空年份，重新折叠
    applyFilter(tags, categories, uncategorized) {
      const foldOnFilter = this.dataset.fold === "true";
      const blocks = Array.from(this.querySelectorAll(".archive-year-block"));
      let totalVisible = 0;
      const visibleBlocks = [];
	  const query = this.searchInput?.value.toLocaleLowerCase().trim() || "";
	  const selectedYear = this.yearSelect?.value || "all";

      for (const block of blocks) {
        const rows = Array.from(block.querySelectorAll(".archive-post"));
        let visibleCount = 0;

        for (const row of rows) {
          let rowTags = [];
          try {
            rowTags = JSON.parse(row.dataset.tags || "[]");
          } catch {
            rowTags = [];
          }
          const rowCategory = row.dataset.category || "";

          let match = true;
          if (tags.length > 0) {
            match = match && rowTags.some((t) => tags.includes(t));
          }
          if (categories.length > 0) {
            match = match && !!rowCategory && categories.includes(rowCategory);
          }
          if (uncategorized) {
            match = match && !rowCategory;
          }
		  if (selectedYear !== "all") {
			match = match && block.dataset.year === selectedYear;
		  }
		  if (query) {
			match =
			  match &&
			  this.matchesArchiveQuery(row.dataset.search || "", query);
		  }

          row.hidden = !match;
          if (match) visibleCount++;
        }

        // 更新每年计数显示
        const countEl = block.querySelector(".archive-year-count");
        const labelEl = block.querySelector(".archive-year-count-label");
        if (countEl) countEl.textContent = String(visibleCount);
        if (labelEl) {
          labelEl.textContent =
            visibleCount === 1 ? i18nStrings.postCount : i18nStrings.postsCount;
        }

        // 隐藏没有可见文章的年份块
        block.hidden = visibleCount === 0;
        if (visibleCount > 0) {
          visibleBlocks.push(block);
          totalVisible += visibleCount;
        }
      }

      // 搜索时保持匹配年份展开，避免每次输入都折叠/展开整块内容造成布局抖动。
      // 清除搜索后再恢复原本的“首个年份展开、其余折叠”布局。
      const shouldAutoCollapse = foldOnFilter && !query;
      visibleBlocks.forEach((block, index) => {
        const shouldCollapse = shouldAutoCollapse && index > 0;
        this.setBlockCollapsed(block, shouldCollapse);
      });

      // 填充并显示筛选头部
      this.renderFilterHeader(tags, categories, uncategorized, totalVisible);
	  const resultCount = this.querySelector("[data-archive-result-count]");
	  if (resultCount) resultCount.textContent = `共 ${totalVisible} 篇文章`;
	  const empty = this.querySelector("[data-archive-empty]");
	  if (empty) empty.hidden = totalVisible > 0;
	  if (this.resetButton) {
		this.resetButton.hidden = !query && selectedYear === "all";
	  }
    }

    setBlockCollapsed(block, collapsed) {
      const content = block.querySelector(".archive-year-content");
      const toggle = block.querySelector(".archive-year-toggle");
      const arrow = block.querySelector(".archive-arrow");
      if (content) content.hidden = collapsed;
      if (toggle) toggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
      if (arrow) {
        arrow.style.transform = collapsed ? "rotate(-90deg)" : "";
      }
    }

    renderFilterHeader(tags, categories, uncategorized, count) {
      const header = this.querySelector("#archive-filter-header");
      if (!header) return;

      // 构造筛选项（tag 优先作为主筛选，镜像原逻辑）
      const filters = [];
      if (categories.length > 0)
        filters.push({ label: i18nStrings.categories, values: categories, isTag: false });
      if (uncategorized)
        filters.push({ label: i18nStrings.categories, values: [i18nStrings.uncategorized], isTag: false });
      if (tags.length > 0)
        filters.push({ label: i18nStrings.tags, values: tags, isTag: true });

      const primary =
        filters.find((f) => f.isTag) || filters[0] || null;
      if (!primary) return;
      const secondary = filters.filter((f) => f !== primary);

      const linkEl = header.querySelector("#archive-filter-link");
      const valuesEl = header.querySelector("#archive-filter-values");
      const secondaryEl = header.querySelector("#archive-filter-secondary");
      const countEl = header.querySelector("#archive-filter-count");
      const countLabelEl = header.querySelector("#archive-filter-count-label");

      const fmtValues = (f) => {
        const prefix = f.isTag ? "#" : "";
        return f.values.map((v) => `${prefix}${v}`).join(" / ");
      };

      if (linkEl) {
        linkEl.textContent = primary.label;
        linkEl.setAttribute("href", primary.isTag ? tagsBaseUrl : categoriesBaseUrl);
      }
      if (valuesEl) valuesEl.textContent = fmtValues(primary);
      if (secondaryEl) {
        if (secondary.length > 0) {
          const summary = secondary
            .map((f) => `${f.label}: ${fmtValues(f)}`)
            .join("  ·  ");
          secondaryEl.textContent = `· ${summary}`;
          secondaryEl.classList.remove("hidden");
        } else {
          secondaryEl.classList.add("hidden");
        }
      }
      if (countEl) countEl.textContent = String(count);
      if (countLabelEl) {
        countLabelEl.textContent =
          count === 1 ? i18nStrings.postCount : i18nStrings.postsCount;
      }

      header.classList.remove("hidden");
    }

    updateBannerTitle(tags, categories, uncategorized) {
      const bannerTitle = document.querySelector(".banner-page-title-text");
      if (!bannerTitle) return;

      let newTitle = "";
      if (categories.length > 0) {
        newTitle = categories.join(" / ");
      } else if (uncategorized) {
        newTitle = i18nStrings.uncategorized;
      } else if (tags.length > 0) {
        newTitle = tags.map((t) => `#${t}`).join(" / ");
      }
      // 直接设置（自定义元素在解析阶段升级、首帧前执行），避免默认标题闪烁
      if (newTitle && bannerTitle.textContent !== newTitle) {
        bannerTitle.textContent = newTitle;
      }
    }

    bindYearToggles() {
      const blocks = Array.from(this.querySelectorAll(".archive-year-block"));
      for (const block of blocks) {
        const toggle = block.querySelector(".archive-year-toggle");
        const content = block.querySelector(".archive-year-content");
        const arrow = block.querySelector(".archive-arrow");
        if (!toggle || !content) continue;

        toggle.addEventListener("click", () => {
          const willCollapse = !content.hidden;
          content.hidden = willCollapse;
          toggle.setAttribute("aria-expanded", willCollapse ? "false" : "true");

          // 用 Web Animations API 做旋转动画，绕开 Swup 对 CSS transition 的干扰
          if (arrow) {
            requestAnimationFrame(() => {
              arrow.animate(
                [
                  { transform: willCollapse ? "rotate(0deg)" : "rotate(-90deg)" },
                  { transform: willCollapse ? "rotate(-90deg)" : "rotate(0deg)" },
                ],
                { duration: 200, easing: "ease", fill: "forwards" },
              );
            });
          }
        });
      }
    }
  }

  if (!customElements.get("archive-panel")) {
    customElements.define("archive-panel", ArchivePanel);
  }
</script>
