---
import { Icon } from "astro-icon/components";
import type { NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
}

const processedLinks = Astro.props.links;
---
<div id="nav-menu-panel" class:list={["float-panel float-panel-closed transition-all fixed right-4 max-h-[80vh] overflow-y-auto jingyue-mobile-nav"]}>
	<header class="jingyue-mobile-nav-heading">
		<span>JINGYUE</span>
		<small>探索我的个人空间</small>
	</header>
    {processedLinks.map((link) => (
        <div class="mobile-menu-item">
            {link.children && link.children.length > 0 ? (
                /* 有子菜单的项目 */
                <div class="mobile-dropdown" data-mobile-dropdown>
                    <button
						type="button"
						class="group jingyue-mobile-trigger"
                        data-mobile-dropdown-trigger
                        aria-expanded="false"
                    >
						<div class="jingyue-mobile-label">
							{link.icon && <Icon is:inline name={link.icon} class="jingyue-mobile-icon" />}
                            {link.name}
                        </div>
                        <Icon is:inline name="material-symbols:keyboard-arrow-down-rounded"
							  class="mobile-dropdown-arrow jingyue-mobile-arrow"
                        />
                    </button>
                    <div class="mobile-submenu" data-mobile-submenu>
                        {link.children.map((child) => (
                            <a href={child.external ? child.url : url(child.url)}
							   class="group jingyue-mobile-child"
                               target={child.external ? "_blank" : null}
                            >
								<div class="jingyue-mobile-label">
									{child.icon && <Icon is:inline name={child.icon} class="jingyue-mobile-icon" />}
                                    {child.name}
                                </div>
                                {child.external && <Icon is:inline name="fa7-solid:arrow-up-right-from-square"
                                      class="transition text-[0.75rem] text-black/25 dark:text-white/25 -translate-x-1"
                                />}
                            </a>
                        ))}
                    </div>
                </div>
            ) : (
                /* 普通链接项目 */
				<a href={link.external ? link.url : url(link.url)} class="group jingyue-mobile-trigger"
                   target={link.external ? "_blank" : null}
                >
					<div class="jingyue-mobile-label">
						{link.icon && <Icon is:inline name={link.icon} class="jingyue-mobile-icon" />}
                        {link.name}
                    </div>
					{!link.external && <Icon is:inline name="material-symbols:chevron-right-rounded"
                          class="transition text-[1.25rem] text-(--primary)"
                    />}
					{link.external && <Icon is:inline name="fa7-solid:arrow-up-right-from-square"
                          class="transition text-[0.75rem] text-black/25 dark:text-white/25 -translate-x-1"
                    />}
                </a>
            )}
        </div>
    ))}
</div>

<style>
    @reference "../../styles/main.css";

    .mobile-submenu {
        @apply max-h-0 overflow-hidden transition-all duration-300 ease-in-out;
    }

    .mobile-dropdown[data-expanded="true"] .mobile-submenu {
        @apply max-h-96;
    }

    .mobile-dropdown[data-expanded="true"] .mobile-dropdown-arrow {
        @apply rotate-180;
    }

	.jingyue-mobile-nav {
		width: min(22rem, calc(100vw - 2rem));
		border: 1px solid color-mix(in oklch, var(--primary) 20%, rgba(255, 255, 255, 0.68));
		border-radius: 1.2rem;
		background: color-mix(in oklch, var(--card-bg) 88%, transparent);
		box-shadow: 0 1.5rem 4rem rgba(18, 31, 46, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.55);
		padding: 0.7rem;
		backdrop-filter: blur(1.4rem) saturate(145%);
	}

	.jingyue-mobile-nav-heading {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin: 0.15rem 0.15rem 0.55rem;
		border-bottom: 1px solid color-mix(in oklch, var(--primary) 18%, transparent);
		padding: 0.55rem 0.65rem 0.75rem;
	}

	.jingyue-mobile-nav-heading span {
		color: color-mix(in oklch, var(--primary) 72%, var(--deep-text, currentColor));
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.2em;
	}

	.jingyue-mobile-nav-heading small {
		color: color-mix(in oklch, var(--deep-text, currentColor) 52%, transparent);
		font-size: 0.62rem;
	}

	.jingyue-mobile-trigger,
	.jingyue-mobile-child {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		min-height: 2.75rem;
		border: 1px solid transparent;
		border-radius: 0.82rem;
		background: transparent;
		padding: 0.58rem 0.72rem;
		color: color-mix(in oklch, var(--deep-text, currentColor) 78%, transparent);
		font-size: 0.84rem;
		font-weight: 760;
		text-align: left;
		text-decoration: none;
		cursor: pointer;
		transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease;
	}

	.jingyue-mobile-child {
		min-height: 2.5rem;
		margin-top: 0.14rem;
		padding-left: 1.55rem;
		color: color-mix(in oklch, var(--deep-text, currentColor) 64%, transparent);
		font-size: 0.78rem;
		font-weight: 650;
	}

	.jingyue-mobile-trigger:hover,
	.jingyue-mobile-trigger:focus-visible,
	.jingyue-mobile-child:hover,
	.jingyue-mobile-child:focus-visible {
		border-color: color-mix(in oklch, var(--primary) 24%, transparent);
		background: color-mix(in oklch, var(--primary) 11%, rgba(255, 255, 255, 0.5));
		color: color-mix(in oklch, var(--primary) 72%, var(--deep-text, currentColor));
		outline: none;
	}

	.jingyue-mobile-trigger:focus-visible,
	.jingyue-mobile-child:focus-visible {
		box-shadow: 0 0 0 2px color-mix(in oklch, var(--primary) 28%, transparent);
	}

	.jingyue-mobile-label {
		display: inline-flex;
		align-items: center;
		gap: 0.58rem;
	}

	:global(.jingyue-mobile-icon),
	:global(.jingyue-mobile-arrow) {
		width: 1.08rem;
		height: 1.08rem;
		color: color-mix(in oklch, var(--primary) 62%, currentColor);
	}

	:global(.jingyue-mobile-arrow) {
		transition: transform 180ms ease;
	}

	:global(html.dark) .jingyue-mobile-nav {
		border-color: color-mix(in oklch, var(--primary) 24%, rgba(255, 255, 255, 0.12));
		background: color-mix(in oklch, var(--card-bg) 90%, rgba(10, 17, 27, 0.28));
		box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.38), inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-submenu,
		.jingyue-mobile-trigger,
		.jingyue-mobile-child,
		:global(.jingyue-mobile-arrow) {
			transition: none !important;
		}
	}
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const mobileDropdowns = document.querySelectorAll('[data-mobile-dropdown]');

        mobileDropdowns.forEach(dropdown => {
            const trigger = dropdown.querySelector('[data-mobile-dropdown-trigger]');
            const submenu = dropdown.querySelector('[data-mobile-submenu]');

            if (!trigger || !submenu) return;

            trigger.addEventListener('click', function(e) {
                e.preventDefault();
                const isExpanded = dropdown.getAttribute('data-expanded') === 'true';

                // 关闭其他打开的下拉菜单
                mobileDropdowns.forEach(otherDropdown => {
                    if (otherDropdown !== dropdown) {
                        otherDropdown.setAttribute('data-expanded', 'false');
                        const otherTrigger = otherDropdown.querySelector('[data-mobile-dropdown-trigger]');
                        if (otherTrigger) {
                            otherTrigger.setAttribute('aria-expanded', 'false');
                        }
                    }
                });

                // 切换当前下拉菜单
                const newState = !isExpanded;
                dropdown.setAttribute('data-expanded', newState.toString());
                trigger.setAttribute('aria-expanded', newState.toString());
            });
        });
    });
</script>
