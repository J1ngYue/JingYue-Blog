		position: absolute;
		left: 50%;
		top: 47%;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 0.12rem;
		background: #f07aa4;
		opacity: 0;
		transform: translate(-50%, -50%) rotate(45deg) scale(0.2);
	}

