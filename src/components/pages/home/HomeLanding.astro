	.home-profile-avatar-wrap:has(.home-profile-avatar-hit:focus-visible) :global(.home-profile-avatar) {
		box-shadow: 0 1.25rem 3.2rem rgba(45, 61, 78, 0.27);
		filter: saturate(1.06) brightness(1.025);
	}

