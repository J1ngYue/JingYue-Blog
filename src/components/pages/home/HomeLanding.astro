			transform: translate(calc(-50% + var(--particle-x)), calc(-50% + var(--particle-y))) rotate(calc(45deg + var(--particle-rotation))) scale(var(--particle-scale));
		}
	}

	@keyframes home-avatar-feedback {
		0% { opacity: 0; transform: translate(-50%, 0.45rem) scale(0.94); }
		14%, 78% { opacity: 1; transform: translate(-50%, 0) scale(1); }
