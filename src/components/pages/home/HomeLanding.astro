	.home-hero {
		position: relative;
		height: 150dvh;
		background: linear-gradient(180deg, #f3eff1, #eceff2);
	}

	.home-hero-sticky {
		position: sticky;
		top: 0;
		height: 100dvh;
		padding: 0;
	}

	.home-hero-frame {
		position: relative;
		isolation: isolate;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background: #eceff2;
	}

	.home-profile-reveal {
		position: absolute;
		inset: 0;
		z-index: -2;
		overflow: hidden;
		opacity: 0;
		background: #eceff2;
		transform: scale(1.018);
		transform-origin: center;
		isolation: isolate;
		pointer-events: none;
		transition:
			opacity 620ms cubic-bezier(0.22, 0.61, 0.36, 1),
			transform 820ms cubic-bezier(0.22, 0.61, 0.36, 1);
		will-change: transform, opacity;
	}

	.home-hero-profile-active .home-profile-reveal {
		opacity: 1;
		transform: scale(1);
	}

	:global(.home-hero-image) {
		position: absolute !important;
		inset: 0;
		z-index: -3;
		width: 100%;
		height: 100%;
		opacity: 1;
		transition: opacity 680ms cubic-bezier(0.22, 0.61, 0.36, 1), filter 680ms ease, transform 520ms ease-out;
	}

	:global(.home-hero-cover-image) {
		opacity: 0;
		transform: none;
