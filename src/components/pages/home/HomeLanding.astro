	.home-cover-particle-arrow {
		--particle-length: 9.4rem;
		--particle-angle: 0rad;
		position: absolute;
		left: 50%;
		top: 50%;
		z-index: 3;
		display: none;
		align-items: center;
		justify-content: flex-end;
		width: var(--particle-length);
		height: 2.8rem;
		opacity: 0;
		color: color-mix(in oklch, var(--primary) 62%, white);
		filter: drop-shadow(0 0 0.7rem color-mix(in oklch, var(--primary) 76%, transparent));
		transform: translateY(-50%) rotate(var(--particle-angle)) scaleX(0.88);
		transform-origin: left center;
		pointer-events: none;
		transition:
			width 110ms ease-out,
			opacity 160ms ease,
			transform 45ms linear;
		will-change: width, transform;
	}

	.home-cover-particle-arrow.is-visible {
		opacity: 1;
		transform: translateY(-50%) rotate(var(--particle-angle)) scaleX(1);
	}

	.home-cover-particle-arrow::before {
		content: "";
		position: absolute;
		left: 0;
		right: 1.15rem;
		width: auto;
		height: 0.34rem;
		border-radius: 999px;
		background:
			linear-gradient(90deg, transparent 0%, color-mix(in oklch, currentColor 35%, transparent) 34%, currentColor 100%)
				center / 100% 0.11rem no-repeat,
			radial-gradient(circle, currentColor 0 0.075rem, transparent 0.1rem) 0 center / 0.72rem 0.34rem repeat-x;
		box-shadow:
			0 0 0.35rem currentColor,
			0 0 1.1rem color-mix(in oklch, var(--primary) 78%, transparent);
		opacity: 0.82;
		transform: scaleX(0.82);
		transform-origin: left center;
		transition: transform 220ms ease, opacity 220ms ease;
	}

	.home-cover-particle-arrow::after {
		content: "";
		position: absolute;
		right: -0.12rem;
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid color-mix(in oklch, currentColor 54%, transparent);
		border-radius: 50%;
		background: radial-gradient(circle, color-mix(in oklch, currentColor 24%, transparent), transparent 68%);
		box-shadow:
			inset 0 0 0.8rem color-mix(in oklch, currentColor 18%, transparent),
			0 0 1.1rem color-mix(in oklch, var(--primary) 54%, transparent);
		opacity: 0.34;
		transform: scale(0.72);
	}

	.home-cover-particle-arrow.is-visible::before {
		opacity: 0.96;
		transform: scaleX(1);
		animation: home-cover-particle-beam 1.45s ease-in-out infinite;
	}

	.home-cover-particle-arrow.is-visible::after {
		animation: home-cover-particle-halo 1.7s ease-in-out infinite;
	}

	.home-cover-particle-arrow i {
		--particle-size: 0.2rem;
		--particle-offset: 0rem;
		--particle-distance: 1.1rem;
		--particle-duration: 1.35s;
		--particle-delay: 0s;
		position: absolute;
		left: var(--particle-left, 10%);
		top: 50%;
		width: var(--particle-size);
		height: var(--particle-size);
		border-radius: 999px;
		background: currentColor;
		box-shadow:
			0 0 0.34rem currentColor,
			0 0 0.8rem color-mix(in oklch, var(--primary) 72%, transparent);
		opacity: 0;
		animation: home-cover-particle-flow var(--particle-duration) ease-out var(--particle-delay) infinite;
		animation-play-state: paused;
	}

	.home-cover-particle-arrow i:nth-child(1) {
		--particle-left: 2%;
		--particle-size: 0.12rem;
		--particle-offset: -0.34rem;
		--particle-delay: -1.1s;
	}

	.home-cover-particle-arrow i:nth-child(2) {
		--particle-left: 8%;
		--particle-size: 0.16rem;
		--particle-offset: 0.42rem;
		--particle-duration: 1.7s;
		--particle-delay: -0.4s;
	}

	.home-cover-particle-arrow i:nth-child(3) {
		--particle-left: 17%;
		--particle-size: 0.2rem;
		--particle-offset: -0.86rem;
		--particle-duration: 1.55s;
		--particle-delay: -0.8s;
	}

	.home-cover-particle-arrow i:nth-child(4) {
		--particle-left: 25%;
		--particle-size: 0.13rem;
		--particle-offset: 0.18rem;
		--particle-delay: -0.15s;
	}

	.home-cover-particle-arrow i:nth-child(5) {
		--particle-left: 34%;
		--particle-size: 0.25rem;
		--particle-offset: 0.92rem;
		--particle-duration: 1.8s;
		--particle-delay: -1.25s;
	}

	.home-cover-particle-arrow i:nth-child(6) {
		--particle-left: 43%;
		--particle-size: 0.16rem;
		--particle-offset: -0.25rem;
		--particle-delay: -0.62s;
	}

	.home-cover-particle-arrow i:nth-child(7) {
