<script is:inline data-swup-ignore-script>
	function initHomeLanding() {
		if (window.__fireflyHomeLandingCleanup) {
			window.__fireflyHomeLandingCleanup();
			window.__fireflyHomeLandingCleanup = null;
		}

		const root = document.querySelector(".home-landing[data-home-landing]");
		if (!root) return;
		const hero = root.querySelector("[data-home-hero]");
		const frame = root.querySelector("[data-home-hero-frame]");
		if (!hero || !frame) return;

		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
		const clock = root.querySelector("[data-home-clock]");
		const date = root.querySelector("[data-home-date]");
		const greeting = root.querySelector("[data-home-greeting]");
		const days = root.querySelector("[data-home-days]");
		const quote = root.querySelector("[data-home-quote]");
		const quoteTriggers = Array.from(root.querySelectorAll("[data-home-quote-trigger]"));
		const musicTrigger = root.querySelector("[data-home-music-trigger]");
		const musicPanel = document.getElementById("music-nav-panel");
		const coverSwitcherTrigger = root.querySelector("[data-home-cover-switcher-trigger]");
		const coverSwitcher = root.querySelector("[data-home-cover-switcher]");
		const coverOrbit = root.querySelector("[data-home-cover-orbit]");
		const particleArrow = root.querySelector("[data-home-cover-particle-arrow]");
		const exhibitTilts = Array.from(root.querySelectorAll("[data-home-exhibit-tilt]"));
		const overviewVideo = root.querySelector("[data-home-overview-video]");
		const profileRail = root.querySelector(".home-profile-rail");
		const coverSwitcherClosers = Array.from(root.querySelectorAll("[data-home-cover-switcher-close]"));
		const coverOptions = Array.from(root.querySelectorAll("[data-home-cover-option]"));
		const homeQuickTools = Array.from(root.querySelectorAll("[data-home-quick-tool]"));
		const coverImages = Array.from(
			root.querySelectorAll("[id^='home-cover-desktop-'], [id^='home-cover-mobile-']"),
		);
		const wordmark = root.querySelector("[data-home-wordmark]");
		const wordmarkGlyphs = Array.from(root.querySelectorAll("[data-home-wordmark-glyph]"));
		const viewportElements = [musicTrigger, profileRail, coverSwitcher]
			.filter(Boolean)
			.map((element) => {
				const placeholder = document.createComment("firefly-home-viewport-element");
				element.before(placeholder);
				document.body.appendChild(element);
				return { element, placeholder };
			});
		const profileTrigger = root.querySelector("[data-home-profile-trigger]");
		const navigationTrigger = root.querySelector("[data-home-navigation-trigger]");
		const coverScene = root.querySelector("[data-home-cover-scene]");
		const profileScene = root.querySelector("[data-home-profile-scene]");
		const scrollScenes = Array.from(root.querySelectorAll("[data-home-scroll-scene]"));
		const terminal = root.querySelector("[data-home-terminal]");
		const profileTerminal = root.querySelector("[data-home-profile-terminal]");
		const avatarTrigger = root.querySelector("[data-home-avatar-trigger]");
		const avatarShell = avatarTrigger?.closest(".home-profile-avatar-wrap");
		const avatarFeedback = root.querySelector("[data-home-avatar-feedback]");
		const avatarResponseLines = avatarTrigger?.dataset.responses
			? JSON.parse(avatarTrigger.dataset.responses)
			: [];
		const desktopSceneNavigation = window.matchMedia("(min-width: 1024px) and (pointer: fine)");
		const timezone = root.dataset.homeTimezone || "Asia/Shanghai";
		const startDate = root.dataset.homeStartDate || "2025-01-01";
		const quotes = quote ? JSON.parse(quote.dataset.quotes || "[]") : [];
		const terminalLines = terminal ? JSON.parse(terminal.dataset.lines || "[]") : [];
		const profileTerminalLines = profileTerminal
			? JSON.parse(profileTerminal.dataset.lines || "[]")
			: [];
		let animationFrame = 0;
		let pageScrollAnimation = 0;
		let sceneMetricsFrame = 0;
		let terminalTimer = 0;
		let profileTerminalTimer = 0;
		let avatarReactionTimer = 0;
		let avatarFeedbackTimer = 0;
		let sceneWheelQuietTimer = 0;
		let musicCloseTimer = 0;
		let coverSwitcherTimer = 0;
		let coverChangeTimer = 0;
		let particleArrowFrame = 0;
		let particleArrowAngle = 0;
		let particleArrowHasAngle = false;
		let exhibitTiltFrame = 0;
		let wordmarkFrame = 0;
		let wordmarkReadyFrame = 0;
		let quoteIndex = 0;
		let avatarResponseIndex = 0;
		let coverSwitcherOpen = false;
		let selectedCoverIndex = Number(
			coverOptions.find((option) => option.classList.contains("is-active"))?.dataset.homeCoverOption ?? 0,
		);
		let profileSceneActive = false;
		let sceneWheelCaptured = false;
		let sceneGestureQuiet = true;
		let sceneAnimationDone = true;
		let sceneTransitioning = false;
		let sceneWheelDelta = 0;
		let sceneWheelDirection = 0;
		let nativeEdgeGesture = false;
		let activeSceneIndex = 0;
		let sceneTargets = [];
		let heroTop = 0;
		let heroScrollDistance = 1;
		let originalScrollBehavior = "";
		let pageScrollBehaviorLocked = false;
		const sceneScrollDuration = 660;
		const sceneWheelThreshold = 24;
		const sceneWheelQuietDelay = 120;
		const sceneEdgeTolerance = 32;

		if (document.documentElement.classList.contains("is-page-transitioning")) {
			window.scrollTo({ top: 0, left: 0, behavior: "auto" });
		}
		frame.classList.remove("home-hero-profile-active");
		coverScene?.removeAttribute("inert");
		coverScene?.setAttribute("aria-hidden", "false");
		profileScene?.setAttribute("inert", "");
		profileScene?.setAttribute("aria-hidden", "true");
		if (profileTerminal) profileTerminal.textContent = "";

		const playWordmark = () => {
			if (!wordmark || wordmarkGlyphs.length === 0) return;
			if (wordmarkFrame) cancelAnimationFrame(wordmarkFrame);
			if (wordmarkReadyFrame) cancelAnimationFrame(wordmarkReadyFrame);
			wordmark.classList.remove("is-ready");
			wordmarkGlyphs.forEach((glyph) => {
				if (!(glyph instanceof SVGPathElement)) return;
				const length = glyph.getTotalLength();
				glyph.style.setProperty("--wordmark-length", String(length));
				glyph.style.strokeDasharray = String(length);
				glyph.style.strokeDashoffset = String(length);
			});
			wordmarkFrame = requestAnimationFrame(() => {
				wordmarkFrame = 0;
				wordmarkReadyFrame = requestAnimationFrame(() => {
					wordmarkReadyFrame = 0;
					wordmark.classList.add("is-ready");
				});
			});
		};

		const setProfileSceneActive = (active) => {
			if (profileSceneActive === active) return;
			profileSceneActive = active;
			frame.classList.toggle("home-hero-profile-active", active);
			coverScene?.toggleAttribute("inert", active);
			coverScene?.setAttribute("aria-hidden", String(active));
			profileScene?.toggleAttribute("inert", !active);
			profileScene?.setAttribute("aria-hidden", String(!active));

			if (active) {
				startProfileTerminal();
			} else {
				if (profileTerminalTimer) window.clearTimeout(profileTerminalTimer);
				if (profileTerminal) profileTerminal.textContent = "";
			}
		};

		const clockFormatter = new Intl.DateTimeFormat("zh-CN", {
			timeZone: timezone,
			hour: "2-digit",
			minute: "2-digit",
			second: "2-digit",
			hourCycle: "h23",
		});
		const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
			timeZone: timezone,
			year: "numeric",
			month: "long",
			day: "numeric",
			weekday: "long",
		});
		const hourFormatter = new Intl.DateTimeFormat("en-US", {
			timeZone: timezone,
			hour: "numeric",
			hourCycle: "h23",
		});

		const updateClock = () => {
			const now = new Date();
			if (clock) {
				clock.textContent = clockFormatter.format(now);
				clock.setAttribute("datetime", now.toISOString());
			}
			if (date) date.textContent = dateFormatter.format(now);
			if (greeting) {
				const hour = Number(hourFormatter.format(now));
				greeting.textContent =
					hour < 5
						? "夜深了"
						: hour < 9
							? "早上好"
							: hour < 12
								? "上午好"
								: hour < 14
									? "中午好"
									: hour < 18
										? "下午好"
										: "晚上好";
			}
			if (days) {
				const startedAt = new Date(`${startDate}T00:00:00`).getTime();
				const elapsedDays = Math.max(1, Math.floor((now.getTime() - startedAt) / 86400000) + 1);
				days.textContent = `已陪伴 ${elapsedDays} 天`;
			}
		};

		const showNextQuote = () => {
			if (!quote || quotes.length < 2) return;
			quoteIndex = (quoteIndex + 1) % quotes.length;
			quote.textContent = quotes[quoteIndex];
		};

		const setMusicDockOpen = (open) => {
			if (!musicPanel) return;
			if (musicCloseTimer) window.clearTimeout(musicCloseTimer);
			musicPanel.classList.toggle("float-panel-closed", !open);
			musicTrigger?.setAttribute("aria-expanded", String(open));
		};

		const openMusicDock = () => setMusicDockOpen(true);
		const scheduleMusicDockClose = () => {
			if (musicCloseTimer) window.clearTimeout(musicCloseTimer);
			musicCloseTimer = window.setTimeout(() => {
				musicCloseTimer = 0;
				const triggerFocused = musicTrigger?.matches(":focus-visible");
				if (
					musicPanel?.matches(":hover, :focus-within") ||
					musicTrigger?.matches(":hover, :focus-visible") ||
					triggerFocused
				) return;
				setMusicDockOpen(false);
			}, 240);
		};

		const openMusicDockFromClick = (event) => {
			event.stopPropagation();
			setMusicDockOpen(true);
		};

		const handleMusicDockKeydown = (event) => {
			if (event.key !== "Escape") return;
			setMusicDockOpen(false);
			musicTrigger?.focus({ preventScroll: true });
		};

		const showAvatarReaction = () => {
			if (!avatarShell || !avatarFeedback || avatarResponseLines.length === 0) return;
			if (avatarReactionTimer) window.clearTimeout(avatarReactionTimer);
			if (avatarFeedbackTimer) window.clearTimeout(avatarFeedbackTimer);

			avatarShell.classList.remove("is-reacting");
			avatarFeedback.classList.remove("is-visible");
			void avatarShell.offsetWidth;

			avatarFeedback.textContent = avatarResponseLines[avatarResponseIndex];
			avatarResponseIndex = (avatarResponseIndex + 1) % avatarResponseLines.length;
			avatarFeedback.hidden = false;
			avatarShell.classList.add("is-reacting");
			avatarFeedback.classList.add("is-visible");

			avatarReactionTimer = window.setTimeout(() => {
				avatarReactionTimer = 0;
				avatarShell.classList.remove("is-reacting");
			}, 900);
			avatarFeedbackTimer = window.setTimeout(() => {
				avatarFeedbackTimer = 0;
				avatarFeedback.classList.remove("is-visible");
				avatarFeedback.hidden = true;
			}, 1_900);
		};

		const pointParticleArrow = (clientX, clientY) => {
			if (!coverOrbit || !particleArrow || reducedMotion.matches) return;
			const rect = coverOrbit.getBoundingClientRect();
			const centerX = rect.left + rect.width / 2;
			const centerY = rect.top + rect.height / 2;
			const deltaX = clientX - centerX;
			const deltaY = clientY - centerY;
			const distance = Math.hypot(deltaX, deltaY);
			const orbitSize = Math.min(rect.width, rect.height);
			const minimumLength = orbitSize * 0.21;
			if (distance < minimumLength * 0.5) {
				particleArrow.classList.remove("is-visible");
				return;
			}
			const maximumLength = orbitSize * 0.43;
			const length = Math.max(minimumLength, Math.min(distance - 18, maximumLength));
			const targetAngle = Math.atan2(deltaY, deltaX);
			if (!particleArrowHasAngle) {
				particleArrowAngle = targetAngle;
				particleArrowHasAngle = true;
			} else {
				// atan2 会在 ±180° 处跳变。把角度连续展开，确保箭头始终走最短路径。
				const shortestDelta = Math.atan2(
					Math.sin(targetAngle - particleArrowAngle),
					Math.cos(targetAngle - particleArrowAngle),
				);
				particleArrowAngle += shortestDelta;
			}

			if (particleArrowFrame) cancelAnimationFrame(particleArrowFrame);
			particleArrowFrame = requestAnimationFrame(() => {
				particleArrowFrame = 0;
				particleArrow.style.setProperty("--particle-length", `${length}px`);
				particleArrow.style.setProperty("--particle-angle", `${particleArrowAngle}rad`);
				particleArrow.classList.add("is-visible");
			});
		};

		const pointParticleArrowToElement = (element) => {
			if (!element) return;
			const rect = element.getBoundingClientRect();
			pointParticleArrow(rect.left + rect.width / 2, rect.top + rect.height / 2);
		};

		const handleCoverOrbitPointerMove = (event) => {
			pointParticleArrow(event.clientX, event.clientY);
		};

		const handleCoverOrbitPointerLeave = () => {
			if (coverOrbit?.contains(document.activeElement)) return;
			particleArrow?.classList.remove("is-visible");
		};

		const handleCoverOrbitFocusIn = (event) => {
			const option = event.target?.closest?.("[data-home-cover-option]");
			if (option) pointParticleArrowToElement(option);
		};

		const resetExhibitTilt = (event) => {
			const exhibitTilt = event.currentTarget;
			if (!exhibitTilt) return;
			if (exhibitTiltFrame) cancelAnimationFrame(exhibitTiltFrame);
			exhibitTiltFrame = 0;
			exhibitTilt.style.setProperty("--exhibit-tilt-x", "0deg");
			exhibitTilt.style.setProperty("--exhibit-tilt-y", "0deg");
			exhibitTilt.classList.remove("is-tilting");
		};

		const handleExhibitTiltPointerMove = (event) => {
			const exhibitTilt = event.currentTarget;
			if (!exhibitTilt || reducedMotion.matches || event.pointerType === "touch") return;
			const rect = exhibitTilt.getBoundingClientRect();
			const relativeX = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
			const relativeY = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
			const rotateX = (relativeY - 0.5) * -4.8;
			const rotateY = (relativeX - 0.5) * 4.8;

			if (exhibitTiltFrame) cancelAnimationFrame(exhibitTiltFrame);
			exhibitTiltFrame = requestAnimationFrame(() => {
				exhibitTiltFrame = 0;
				exhibitTilt.style.setProperty("--exhibit-tilt-x", `${rotateX.toFixed(2)}deg`);
				exhibitTilt.style.setProperty("--exhibit-tilt-y", `${rotateY.toFixed(2)}deg`);
				exhibitTilt.classList.add("is-tilting");
			});
		};

		const handleLocalCoverState = (event) => {
			const localCoverActive = Boolean(event.detail?.active);
			coverSwitcher?.classList.toggle("has-local-cover", localCoverActive);
			coverOptions.forEach((option) => {
				const active = !localCoverActive && Number(option.dataset.homeCoverOption) === selectedCoverIndex;
				option.classList.toggle("is-active", active);
				option.setAttribute("aria-pressed", String(active));
			});
		};

		const handleHomeQuickTool = (event) => {
			const action = event.currentTarget?.dataset.homeQuickTool;
			const targetId = {
				navigation: "quick-tools-navigation",
				search: "quick-tools-search",
				settings: "quick-tools-settings",
			}[action];
			if (targetId) document.getElementById(targetId)?.click();
		};

		homeQuickTools.forEach((tool) => {
			if (tool.dataset.homeQuickTool !== "home") {
				tool.addEventListener("click", handleHomeQuickTool);
			}
		});

		const setCoverSwitcherOpen = (open, restoreFocus = true) => {
			if (!coverSwitcher || !coverSwitcherTrigger || coverSwitcherOpen === open) return;
			coverSwitcherOpen = open;
			if (coverSwitcherTimer) window.clearTimeout(coverSwitcherTimer);
			coverSwitcherTrigger.setAttribute("aria-expanded", String(open));
			coverSwitcher.setAttribute("aria-hidden", String(!open));
			document.body.classList.toggle("home-cover-switcher-open", open);

			if (open) {
				coverSwitcher.hidden = false;
				requestAnimationFrame(() => {
					coverSwitcher.classList.add("is-open");
					const activeOption = coverOptions.find((option) => option.classList.contains("is-active"));
					(activeOption || coverOptions[0] || coverSwitcher.querySelector("button"))?.focus({ preventScroll: true });
				});
				return;
			}

			coverSwitcher.classList.remove("is-open");
			particleArrow?.classList.remove("is-visible");
			particleArrowHasAngle = false;
			coverSwitcherTimer = window.setTimeout(() => {
				coverSwitcherTimer = 0;
				coverSwitcher.hidden = true;
			}, 260);
			if (restoreFocus) coverSwitcherTrigger.focus({ preventScroll: true });
		};

		const openCoverSwitcher = () => setCoverSwitcherOpen(true);
		const closeCoverSwitcher = () => setCoverSwitcherOpen(false);
		const openWallpaperSwitcherFromQuery = () => {
			const target = new URL(window.location.href);
			if (target.searchParams.get("wallpaper") !== "1") return;
			target.searchParams.delete("wallpaper");
			window.history.replaceState(window.history.state, "", target);
			requestAnimationFrame(() => requestAnimationFrame(openCoverSwitcher));
		};
		openWallpaperSwitcherFromQuery();

		const selectCoverIllustration = (event) => {
			const option = event.currentTarget;
			const nextIndex = Number(option.dataset.homeCoverOption);
			if (!Number.isInteger(nextIndex)) return;
			selectedCoverIndex = nextIndex;
			window.dispatchEvent(new CustomEvent("jingyue:select-built-in-cover"));

			coverImages.forEach((image) => {
				const imageIndex = Number(image.id.match(/(\d+)$/)?.[1]);
				image.classList.toggle("is-active", imageIndex === nextIndex);
			});
			coverOptions.forEach((item) => {
				const active = Number(item.dataset.homeCoverOption) === nextIndex;
				item.classList.toggle("is-active", active);
				item.setAttribute("aria-pressed", String(active));
			});

			root.classList.add("home-cover-changing");
			if (coverChangeTimer) window.clearTimeout(coverChangeTimer);
			coverChangeTimer = window.setTimeout(() => {
				coverChangeTimer = 0;
				root.classList.remove("home-cover-changing");
			}, 760);
			playWordmark();
			setCoverSwitcherOpen(false);
		};

		const handleCoverSwitcherKeydown = (event) => {
			if (!coverSwitcherOpen || !coverSwitcher) return;
			if (event.key === "Escape") {
				event.preventDefault();
				setCoverSwitcherOpen(false);
				return;
			}
			if (event.key !== "Tab") return;
			const focusable = Array.from(coverSwitcher.querySelectorAll("button:not([disabled])"));
			if (focusable.length === 0) return;
			const first = focusable[0];
			const last = focusable[focusable.length - 1];
			if (event.shiftKey && document.activeElement === first) {
				event.preventDefault();
				last.focus();
			} else if (!event.shiftKey && document.activeElement === last) {
				event.preventDefault();
				first.focus();
			}
		};

		const lockPageScrollBehavior = () => {
			if (!pageScrollBehaviorLocked) {
				originalScrollBehavior = document.documentElement.style.scrollBehavior;
				pageScrollBehaviorLocked = true;
			}
			document.documentElement.style.scrollBehavior = "auto";
		};

		const unlockPageScrollBehavior = () => {
			if (!pageScrollBehaviorLocked) return;
			document.documentElement.style.scrollBehavior = originalScrollBehavior;
			pageScrollBehaviorLocked = false;
		};

		function animatePageScroll(targetY, duration = sceneScrollDuration, onComplete) {
			if (pageScrollAnimation) cancelAnimationFrame(pageScrollAnimation);
			lockPageScrollBehavior();
			const maxScroll = Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
			const destination = Math.min(maxScroll, Math.max(0, targetY));
			const startY = window.scrollY;
			const distance = destination - startY;
			if (reducedMotion.matches || Math.abs(distance) < 2) {
				window.scrollTo(0, destination);
				pageScrollAnimation = 0;
				unlockPageScrollBehavior();
				onComplete?.();
				return;
			}

			const startedAt = performance.now();
			const step = (now) => {
				const progress = Math.min(1, (now - startedAt) / duration);
				const eased = 0.5 - Math.cos(Math.PI * progress) / 2;
				window.scrollTo(0, startY + distance * eased);
				if (progress < 1) {
					pageScrollAnimation = requestAnimationFrame(step);
				} else {
					window.scrollTo(0, destination);
					pageScrollAnimation = 0;
					unlockPageScrollBehavior();
					onComplete?.();
				}
			};

			pageScrollAnimation = requestAnimationFrame(step);
		}

		const getElementPageTop = (element) => {
			let top = 0;
			let current = element;
			while (current) {
				top += current.offsetTop;
				current = current.offsetParent;
			}
			return top;
		};

		const getClosestSceneIndex = (targets = sceneTargets) => {
			let closestIndex = 0;
			let closestDistance = Number.POSITIVE_INFINITY;
			targets.forEach((target, index) => {
				const distance = Math.abs(window.scrollY - target);
				if (distance < closestDistance) {
					closestDistance = distance;
					closestIndex = index;
				}
			});
			return closestIndex;
		};

		const setActiveSceneIndex = (index) => {
			activeSceneIndex = Math.max(0, Math.min(sceneTargets.length - 1, index));
			root.dataset.homeSceneIndex = String(activeSceneIndex);
		};

		const updateSceneMetrics = () => {
			heroTop = getElementPageTop(hero);
			heroScrollDistance = Math.max(hero.offsetHeight - window.innerHeight, 1);
			sceneTargets = [
				heroTop,
				heroTop + heroScrollDistance,
				...scrollScenes.map((scene) => getElementPageTop(scene)),
			];
			if (!sceneTransitioning) setActiveSceneIndex(getClosestSceneIndex(sceneTargets));
		};

		const releaseSceneWheelIfReady = () => {
			if (!sceneAnimationDone || !sceneGestureQuiet) return;
			sceneWheelCaptured = false;
			sceneWheelDelta = 0;
			sceneWheelDirection = 0;
		};

		const scheduleSceneGestureQuiet = () => {
			sceneGestureQuiet = false;
			if (sceneWheelQuietTimer) window.clearTimeout(sceneWheelQuietTimer);
			sceneWheelQuietTimer = window.setTimeout(() => {
				sceneWheelQuietTimer = 0;
				sceneGestureQuiet = true;
				sceneWheelDelta = 0;
				sceneWheelDirection = 0;
				nativeEdgeGesture = false;
				releaseSceneWheelIfReady();
			}, sceneWheelQuietDelay);
		};

		const normalizeWheelDelta = (event, value) => {
			const multiplier =
				event.deltaMode === WheelEvent.DOM_DELTA_LINE
					? 16
					: event.deltaMode === WheelEvent.DOM_DELTA_PAGE
						? window.innerHeight
						: 1;
			const pixels = value * multiplier;
			return Math.sign(pixels) * Math.min(Math.abs(pixels), 120);
		};

		const cancelSceneNavigation = () => {
			if (pageScrollAnimation) cancelAnimationFrame(pageScrollAnimation);
			pageScrollAnimation = 0;
			if (sceneWheelQuietTimer) window.clearTimeout(sceneWheelQuietTimer);
			sceneWheelQuietTimer = 0;
			sceneTransitioning = false;
			sceneAnimationDone = true;
			sceneGestureQuiet = true;
			sceneWheelCaptured = false;
			sceneWheelDelta = 0;
			sceneWheelDirection = 0;
			nativeEdgeGesture = false;
			root.classList.remove("is-scene-transitioning");
			unlockPageScrollBehavior();
		};

		const navigateToScene = (nextIndex) => {
			updateSceneMetrics();
			const safeIndex = Math.max(0, Math.min(sceneTargets.length - 1, nextIndex));
			setActiveSceneIndex(safeIndex);
			sceneWheelCaptured = true;
			sceneAnimationDone = false;
			sceneTransitioning = true;
			root.classList.add("is-scene-transitioning");
			setProfileSceneActive(safeIndex > 0);
			animatePageScroll(sceneTargets[safeIndex], sceneScrollDuration, () => {
				sceneTransitioning = false;
				sceneAnimationDone = true;
				root.classList.remove("is-scene-transitioning");
				render();
				releaseSceneWheelIfReady();
			});
		};

		const handleHomeWheel = (event) => {
			if (
				reducedMotion.matches ||
				!desktopSceneNavigation.matches ||
				event.ctrlKey ||
				event.shiftKey ||
				Math.abs(event.deltaX) > Math.abs(event.deltaY) * 1.15
			) return;

			const eventTarget = event.target instanceof Element ? event.target : null;
			if (
				coverSwitcherOpen ||
				eventTarget?.closest("#music-nav-panel, #display-setting, [data-home-cover-switcher], input, textarea, select")
			) return;

			const deltaY = normalizeWheelDelta(event, event.deltaY);
			if (Math.abs(deltaY) < 0.1) return;
			const direction = deltaY > 0 ? 1 : -1;

			if (sceneTransitioning || sceneWheelCaptured) {
				event.preventDefault();
				scheduleSceneGestureQuiet();
				return;
			}

			if (sceneWheelDelta === 0 && sceneWheelDirection === 0) updateSceneMetrics();
			setActiveSceneIndex(getClosestSceneIndex(sceneTargets));
			const lastSceneIndex = sceneTargets.length - 1;
			const beyondLastScene =
				window.scrollY > (sceneTargets[lastSceneIndex] ?? 0) + sceneEdgeTolerance;
			if (
				nativeEdgeGesture ||
				beyondLastScene ||
				(activeSceneIndex === lastSceneIndex && direction > 0)
			) {
				nativeEdgeGesture = true;
				scheduleSceneGestureQuiet();
				return;
			}

			event.preventDefault();
			scheduleSceneGestureQuiet();
			if (sceneWheelDirection !== 0 && sceneWheelDirection !== direction) sceneWheelDelta = 0;
			sceneWheelDirection = direction;
			sceneWheelDelta += deltaY;
			if (Math.abs(sceneWheelDelta) < sceneWheelThreshold) return;

			sceneWheelDelta = 0;
			const nextIndex = Math.max(
				0,
				Math.min(sceneTargets.length - 1, activeSceneIndex + direction),
			);
			if (nextIndex === activeSceneIndex) {
				sceneWheelCaptured = true;
				sceneAnimationDone = true;
				releaseSceneWheelIfReady();
				return;
			}
			navigateToScene(nextIndex);
		};

		const showNavigationScene = (event) => {
			event.preventDefault();
			navigateToScene(2);
		};

		const showProfileScene = (event) => {
			event.preventDefault();
			navigateToScene(reducedMotion.matches ? 2 : 1);
		};

		const startTerminal = () => {
			if (!terminal || terminalLines.length === 0) return;
			if (terminalTimer) window.clearTimeout(terminalTimer);
			if (reducedMotion.matches) {
				terminal.textContent = terminalLines[0];
				return;
			}

			let lineIndex = 0;
			let characterIndex = 0;
			let deleting = false;
			const type = () => {
				const line = terminalLines[lineIndex];
				characterIndex += deleting ? -1 : 1;
				terminal.textContent = line.slice(0, characterIndex);
				let delay = deleting ? 42 : 72;

				if (!deleting && characterIndex >= line.length) {
					deleting = true;
					delay = 1600;
				} else if (deleting && characterIndex <= 0) {
					deleting = false;
					lineIndex = (lineIndex + 1) % terminalLines.length;
					delay = 320;
				}

				terminalTimer = window.setTimeout(type, delay);
			};

			terminal.textContent = "";
			terminalTimer = window.setTimeout(type, 450);
		};

		function startProfileTerminal() {
			if (!profileTerminal || profileTerminalLines.length === 0) return;
			if (profileTerminalTimer) window.clearTimeout(profileTerminalTimer);
			if (reducedMotion.matches) {
				profileTerminal.textContent = profileTerminalLines[0];
				return;
			}

			let lineIndex = 0;
			let characterIndex = 0;
			let deleting = false;
			const type = () => {
				if (!profileSceneActive) return;
				const line = profileTerminalLines[lineIndex];
				characterIndex += deleting ? -1 : 1;
				profileTerminal.textContent = line.slice(0, characterIndex);
				let delay = deleting ? 38 : 82;

				if (!deleting && characterIndex >= line.length) {
					deleting = true;
					delay = 1500;
				} else if (deleting && characterIndex <= 0) {
					deleting = false;
					lineIndex = (lineIndex + 1) % profileTerminalLines.length;
					delay = 320;
				}

				profileTerminalTimer = window.setTimeout(type, delay);
			};

			profileTerminal.textContent = "";
			profileTerminalTimer = window.setTimeout(type, 520);
		}

		updateSceneMetrics();
		sceneMetricsFrame = requestAnimationFrame(() => {
			sceneMetricsFrame = 0;
			updateSceneMetrics();
		});
		root.setAttribute("data-home-scenes-ready", "true");
		let sceneObserver = null;
		let overviewVideoObserver = null;
		const markOverviewVideoPlaying = () => {
			overviewVideo?.classList.add("is-playing");
		};
		if ("IntersectionObserver" in window) {
			sceneObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						entry.target.classList.toggle("is-visible", entry.isIntersecting);
					});
				},
				{ threshold: 0.2 },
			);
			scrollScenes.forEach((scene) => sceneObserver.observe(scene));
			if (overviewVideo) {
				overviewVideoObserver = new IntersectionObserver(
					([entry]) => {
						if (entry.isIntersecting) {
							overviewVideo.play().catch(() => {});
						} else {
							overviewVideo.pause();
						}
					},
					{ rootMargin: "240px 0px", threshold: 0.15 },
				);
				overviewVideoObserver.observe(overviewVideo);
			}
		} else {
			scrollScenes.forEach((scene) => scene.classList.add("is-visible"));
			overviewVideo?.play().catch(() => {});
		}
		overviewVideo?.addEventListener("playing", markOverviewVideoPlaying);

		updateClock();
		const clockInterval = window.setInterval(updateClock, 1000);
		quoteTriggers.forEach((trigger) => trigger.addEventListener("click", showNextQuote));
		avatarTrigger?.addEventListener("click", showAvatarReaction);
		musicTrigger?.addEventListener("click", openMusicDockFromClick);
		musicTrigger?.addEventListener("pointerenter", openMusicDock);
		musicTrigger?.addEventListener("pointerleave", scheduleMusicDockClose);
		musicTrigger?.addEventListener("focus", openMusicDock);
		musicTrigger?.addEventListener("blur", scheduleMusicDockClose);
		musicTrigger?.addEventListener("keydown", handleMusicDockKeydown);
		musicPanel?.addEventListener("pointerenter", openMusicDock);
		musicPanel?.addEventListener("pointerleave", scheduleMusicDockClose);
		musicPanel?.addEventListener("focusin", openMusicDock);
		musicPanel?.addEventListener("focusout", scheduleMusicDockClose);
		musicPanel?.addEventListener("keydown", handleMusicDockKeydown);
		coverSwitcherTrigger?.addEventListener("click", openCoverSwitcher);
		coverSwitcherClosers.forEach((closer) => closer.addEventListener("click", closeCoverSwitcher));
		coverOptions.forEach((option) => option.addEventListener("click", selectCoverIllustration));
		coverSwitcher?.addEventListener("keydown", handleCoverSwitcherKeydown);
		coverOrbit?.addEventListener("pointermove", handleCoverOrbitPointerMove);
		coverOrbit?.addEventListener("pointerleave", handleCoverOrbitPointerLeave);
		coverOrbit?.addEventListener("focusin", handleCoverOrbitFocusIn);
		exhibitTilts.forEach((exhibitTilt) => {
			exhibitTilt.addEventListener("pointermove", handleExhibitTiltPointerMove);
			exhibitTilt.addEventListener("pointerleave", resetExhibitTilt);
			exhibitTilt.addEventListener("pointercancel", resetExhibitTilt);
		});
		window.addEventListener("jingyue:local-cover-state-change", handleLocalCoverState);
		profileTrigger?.addEventListener("click", showProfileScene);
		navigationTrigger?.addEventListener("click", showNavigationScene);
		window.addEventListener("wheel", handleHomeWheel, { passive: false });
		playWordmark();
		startTerminal();

		const render = () => {
			animationFrame = 0;
			if (sceneTransitioning) return;
			if (reducedMotion.matches) {
				setProfileSceneActive(false);
				return;
			}

			const profileSceneEnd = sceneTargets[2] ?? heroTop + hero.offsetHeight;
			if (window.scrollY >= profileSceneEnd - 1) {
				setProfileSceneActive(false);
				return;
			}

			const progress = Math.min(
				1,
				Math.max(0, (window.scrollY - heroTop) / heroScrollDistance),
			);
			if (!profileSceneActive && progress >= 0.12) setProfileSceneActive(true);
			if (profileSceneActive && progress <= 0.035) setProfileSceneActive(false);
		};

		const scheduleRender = () => {
			if (!animationFrame) animationFrame = requestAnimationFrame(render);
		};
		const handleMotionPreference = () => {
			cancelSceneNavigation();
			if (sceneMetricsFrame) cancelAnimationFrame(sceneMetricsFrame);
			sceneMetricsFrame = requestAnimationFrame(() => {
				sceneMetricsFrame = 0;
				updateSceneMetrics();
				render();
				startTerminal();
			});
		};
		const handleViewportResize = () => {
			const preservedSceneIndex = activeSceneIndex;
			const previousTarget = sceneTargets[preservedSceneIndex] ?? window.scrollY;
			const preserveSnappedScene =
				sceneTransitioning ||
				Math.abs(window.scrollY - previousTarget) <= sceneEdgeTolerance;
			cancelSceneNavigation();
			if (sceneMetricsFrame) cancelAnimationFrame(sceneMetricsFrame);
			sceneMetricsFrame = requestAnimationFrame(() => {
				sceneMetricsFrame = 0;
				updateSceneMetrics();
				if (
					preserveSnappedScene &&
					desktopSceneNavigation.matches &&
					!reducedMotion.matches
				) {
					setActiveSceneIndex(preservedSceneIndex);
					window.scrollTo(0, sceneTargets[preservedSceneIndex] ?? window.scrollY);
				}
				render();
			});
		};

		window.addEventListener("scroll", scheduleRender, { passive: true });
		window.addEventListener("resize", handleViewportResize);
		reducedMotion.addEventListener("change", handleMotionPreference);
		render();

		window.__fireflyHomeLandingCleanup = () => {
			window.removeEventListener("scroll", scheduleRender);
			window.removeEventListener("resize", handleViewportResize);
			reducedMotion.removeEventListener("change", handleMotionPreference);
			quoteTriggers.forEach((trigger) => trigger.removeEventListener("click", showNextQuote));
			avatarTrigger?.removeEventListener("click", showAvatarReaction);
			musicTrigger?.removeEventListener("click", openMusicDockFromClick);
			musicTrigger?.removeEventListener("pointerenter", openMusicDock);
			musicTrigger?.removeEventListener("pointerleave", scheduleMusicDockClose);
			musicTrigger?.removeEventListener("focus", openMusicDock);
			musicTrigger?.removeEventListener("blur", scheduleMusicDockClose);
			musicTrigger?.removeEventListener("keydown", handleMusicDockKeydown);
			musicPanel?.removeEventListener("pointerenter", openMusicDock);
			musicPanel?.removeEventListener("pointerleave", scheduleMusicDockClose);
			musicPanel?.removeEventListener("focusin", openMusicDock);
			musicPanel?.removeEventListener("focusout", scheduleMusicDockClose);
			musicPanel?.removeEventListener("keydown", handleMusicDockKeydown);
			coverSwitcherTrigger?.removeEventListener("click", openCoverSwitcher);
			coverSwitcherClosers.forEach((closer) => closer.removeEventListener("click", closeCoverSwitcher));
			coverOptions.forEach((option) => option.removeEventListener("click", selectCoverIllustration));
			homeQuickTools.forEach((tool) => {
				if (tool.dataset.homeQuickTool !== "home") {
					tool.removeEventListener("click", handleHomeQuickTool);
				}
			});
			coverSwitcher?.removeEventListener("keydown", handleCoverSwitcherKeydown);
			coverOrbit?.removeEventListener("pointermove", handleCoverOrbitPointerMove);
			coverOrbit?.removeEventListener("pointerleave", handleCoverOrbitPointerLeave);
			coverOrbit?.removeEventListener("focusin", handleCoverOrbitFocusIn);
			exhibitTilts.forEach((exhibitTilt) => {
				exhibitTilt.removeEventListener("pointermove", handleExhibitTiltPointerMove);
				exhibitTilt.removeEventListener("pointerleave", resetExhibitTilt);
				exhibitTilt.removeEventListener("pointercancel", resetExhibitTilt);
			});
			overviewVideo?.removeEventListener("playing", markOverviewVideoPlaying);
			overviewVideo?.pause();
			window.removeEventListener("jingyue:local-cover-state-change", handleLocalCoverState);
			profileTrigger?.removeEventListener("click", showProfileScene);
			navigationTrigger?.removeEventListener("click", showNavigationScene);
			window.removeEventListener("wheel", handleHomeWheel);
			sceneObserver?.disconnect();
			overviewVideoObserver?.disconnect();
			root.removeAttribute("data-home-scenes-ready");
			root.removeAttribute("data-home-scene-index");
			root.classList.remove("is-scene-transitioning");
			setMusicDockOpen(false);
			if (coverSwitcherOpen) setCoverSwitcherOpen(false, false);
			document.body.classList.remove("home-cover-switcher-open");
			window.clearInterval(clockInterval);
			if (terminalTimer) window.clearTimeout(terminalTimer);
			if (profileTerminalTimer) window.clearTimeout(profileTerminalTimer);
			if (avatarReactionTimer) window.clearTimeout(avatarReactionTimer);
			if (avatarFeedbackTimer) window.clearTimeout(avatarFeedbackTimer);
			if (sceneWheelQuietTimer) window.clearTimeout(sceneWheelQuietTimer);
			if (musicCloseTimer) window.clearTimeout(musicCloseTimer);
			if (coverSwitcherTimer) window.clearTimeout(coverSwitcherTimer);
			if (coverChangeTimer) window.clearTimeout(coverChangeTimer);
			if (particleArrowFrame) cancelAnimationFrame(particleArrowFrame);
			if (exhibitTiltFrame) cancelAnimationFrame(exhibitTiltFrame);
			if (animationFrame) cancelAnimationFrame(animationFrame);
			if (pageScrollAnimation) cancelAnimationFrame(pageScrollAnimation);
			if (sceneMetricsFrame) cancelAnimationFrame(sceneMetricsFrame);
			if (wordmarkFrame) cancelAnimationFrame(wordmarkFrame);
			if (wordmarkReadyFrame) cancelAnimationFrame(wordmarkReadyFrame);
			unlockPageScrollBehavior();
			viewportElements.forEach(({ element, placeholder }) => {
				placeholder.before(element);
				placeholder.remove();
			});
		};
	}

	initHomeLanding();
	if (!window.__fireflyHomeLandingBound) {
		window.__fireflyHomeLandingBound = true;
		document.addEventListener("swup:contentReplaced", initHomeLanding);
		document.addEventListener("astro:page-load", initHomeLanding);
	}

	function bindHomeLandingSwup() {
		if (window.__fireflyHomeLandingSwupBound || !window.swup?.hooks) return;
		window.__fireflyHomeLandingSwupBound = true;
		window.swup.hooks.on("content:replace", initHomeLanding);
	}

	if (window.swup?.hooks) {
		bindHomeLandingSwup();
	} else {
		document.addEventListener("swup:enable", bindHomeLandingSwup, {
			once: true,
		});
	}
</script>

