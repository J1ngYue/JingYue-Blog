		content: "";
		position: absolute;
		inset: 0.5rem;
		border: 1px solid color-mix(in oklch, var(--primary) 58%, white);
		border-radius: inherit;
		box-shadow: 0 0 0 0 color-mix(in oklch, var(--primary) 24%, transparent);
		opacity: 0;
		transform: scale(0.92);
		transition: opacity 180ms ease, transform 180ms ease, box-shadow 180ms ease;
	}

