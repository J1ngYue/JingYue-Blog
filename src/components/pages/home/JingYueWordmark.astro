---

<span class="jingyue-wordmark" data-home-wordmark aria-hidden="true">
	<svg viewBox="0 42 568.1 205" focusable="false">
		<defs>
			<linearGradient id="jingyue-wordmark-stroke" x1="8%" y1="15%" x2="94%" y2="82%">
				<stop offset="0%" class="wordmark-stroke-start"></stop>
				<stop offset="52%" class="wordmark-stroke-middle"></stop>
				<stop offset="100%" class="wordmark-stroke-end"></stop>
			</linearGradient>
			<linearGradient id="jingyue-wordmark-fill" x1="6%" y1="12%" x2="96%" y2="84%">
				<stop offset="0%" class="wordmark-fill-start"></stop>
				<stop offset="58%" class="wordmark-fill-middle"></stop>
				<stop offset="100%" class="wordmark-fill-end"></stop>
			</linearGradient>
		</defs>
		<g transform="translate(45.5 169.39)">
			{glyphs.map((glyph, index) => (
				<path
					class="jingyue-wordmark-glyph"
					data-home-wordmark-glyph
					d={glyph.d}
					fill="url(#jingyue-wordmark-fill)"
					stroke="url(#jingyue-wordmark-stroke)"
					style={`--wordmark-delay: ${index * 0.24}s`}
				></path>
			))}
		</g>
	</svg>
</span>

<style>
	.jingyue-wordmark {
		--wordmark-glow: color-mix(in oklch, var(--primary) 54%, white);
		position: relative;
		isolation: isolate;
		display: block;
		width: 100%;
		pointer-events: none;
	}

	.jingyue-wordmark::before {
		position: absolute;
		inset: 20% 1% 12%;
		z-index: -1;
		border-radius: 999px;
		background: radial-gradient(ellipse at center, var(--wordmark-glow), transparent 72%);
		filter: blur(1.5rem);
		opacity: 0;
		content: "";
	}

	.jingyue-wordmark.is-ready::before {
		animation: jingyue-wordmark-glow 4.5s ease-in-out 2.75s infinite;
	}

	.jingyue-wordmark svg {
		display: block;
		width: 100%;
		height: auto;
		overflow: visible;
		filter:
			drop-shadow(0 0 0.35rem color-mix(in oklch, var(--primary) 42%, transparent))
			drop-shadow(0 0.45rem 0.85rem rgba(0, 0, 0, 0.22));
	}

	.jingyue-wordmark-glyph {
		--wordmark-length: 1;
		fill-opacity: 0;
		stroke-width: 2.6;
		stroke-linecap: round;
		stroke-linejoin: round;
		opacity: 0;
		will-change: stroke-dashoffset, fill-opacity, opacity;
	}

	.jingyue-wordmark.is-ready .jingyue-wordmark-glyph {
		animation:
			jingyue-wordmark-draw 0.6s cubic-bezier(0.45, 0, 0.25, 1) var(--wordmark-delay) forwards,
			jingyue-wordmark-show 0.01s linear var(--wordmark-delay) forwards,
			jingyue-wordmark-fill 1.2s ease-out calc(var(--wordmark-delay) + 0.8s) forwards;
	}

	.wordmark-stroke-start {
		stop-color: #fffdf8;
	}

	.wordmark-stroke-middle {
		stop-color: color-mix(in oklch, var(--primary) 54%, white);
	}

	.wordmark-stroke-end {
		stop-color: color-mix(in oklch, var(--primary) 78%, #fff3f8);
	}

	.wordmark-fill-start {
		stop-color: rgba(255, 255, 255, 0.96);
	}

	.wordmark-fill-middle {
		stop-color: color-mix(in oklch, var(--primary) 34%, white);
	}

	.wordmark-fill-end {
		stop-color: color-mix(in oklch, var(--primary) 62%, #fff5f8);
	}

	@keyframes jingyue-wordmark-draw {
		0% {
			stroke-dashoffset: var(--wordmark-length);
			stroke-width: 3.2;
		}
		60% {
			stroke-width: 2.8;
		}
		100% {
			stroke-dashoffset: 0;
			stroke-width: 2.6;
		}
	}

	@keyframes jingyue-wordmark-show {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes jingyue-wordmark-fill {
		from {
			fill-opacity: 0;
		}
		to {
			fill-opacity: 1;
		}
	}

	@keyframes jingyue-wordmark-glow {
		0%,
		100% {
			opacity: 0.08;
			transform: scale(1);
		}
		50% {
			opacity: 0.24;
			transform: scale(1.035);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.jingyue-wordmark,
		.jingyue-wordmark::before,
		.jingyue-wordmark-glyph {
			animation: none !important;
		}

		.jingyue-wordmark-glyph {
			fill-opacity: 1;
			stroke-dashoffset: 0 !important;
			opacity: 1;
			will-change: auto;
		}
	}
</style>
