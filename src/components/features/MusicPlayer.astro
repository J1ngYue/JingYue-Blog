	async function syncNeteasePlaylist(playlistId) {
		var id = String(playlistId || '').trim();
		if (!/^\d+$/.test(id)) {
			setNeteaseStatus('请输入正确的数字歌单 ID', 'error');
			return;
		}
		setNeteaseStatus('正在读取歌单…');
		setLoading(true);
		try {
			await mgr.syncMetingPlaylist(id);
			localStorage.setItem('jingyue-netease-playlist-id', id);
		} catch (error) {
			setLoading(false);
			setNeteaseStatus(error instanceof Error ? error.message : '同步失败，请稍后重试', 'error');
		}
	}

	async function neteaseApi(path, params) {
		var base = String(cfg.neteaseSync.apiBaseUrl || '').replace(/\/$/, '');
		if (!base) return Promise.reject(new Error('尚未配置网易云登录接口'));
		var requestUrl = new URL(base + path);
		Object.keys(params || {}).forEach(function (key) {
			if (params[key] !== undefined && params[key] !== null && params[key] !== '') {
				requestUrl.searchParams.set(key, String(params[key]));
			}
		});
		requestUrl.searchParams.set('timestamp', String(Date.now()));
		return fetch(requestUrl.toString()).then(function (response) {
			if (!response.ok) throw new Error('接口请求失败（' + response.status + '）');
			return response.json();
		});
	}

	function renderNeteasePlaylists(playlists) {
		ui.neteaseSelect.innerHTML = '';
		playlists.forEach(function (playlist) {
			var option = document.createElement('option');
			option.value = String(playlist.id);
			option.textContent = playlist.name + ' · ' + (playlist.trackCount || 0) + ' 首';
			ui.neteaseSelect.appendChild(option);
		});
		ui.neteaseSelect.classList.remove('hidden');
		ui.neteaseApply.classList.remove('hidden');
		ui.neteaseLogin.classList.add('hidden');
		setNeteaseStatus('已读取 ' + playlists.length + ' 个歌单，请选择后载入。', 'success');
	}

	async function loadNeteaseAccount(cookie) {
		var loginStatus = await neteaseApi('/login/status', { cookie: cookie });
		var profile = loginStatus.data?.profile || loginStatus.profile;
		var userId = profile?.userId || loginStatus.data?.account?.id || loginStatus.account?.id;
		if (!userId) throw new Error('登录成功，但未读取到用户信息');
		var result = await neteaseApi('/user/playlist', {
			uid: userId,
			limit: cfg.neteaseSync.playlistLimit || 50,
			cookie: cookie
		});
		var playlists = Array.isArray(result.playlist) ? result.playlist : [];
		if (playlists.length === 0) throw new Error('账号中没有可读取的歌单');
		renderNeteasePlaylists(playlists);
	}

	function pollNeteaseQr(key) {
		if (local.qrPollTimer) window.clearTimeout(local.qrPollTimer);
		local.qrPollTimer = window.setTimeout(async function checkQr() {
			try {
				var result = await neteaseApi('/login/qr/check', { key: key });
				if (result.code === 800) {
					setNeteaseStatus('二维码已过期，请重新生成', 'error');
					return;
				}
				if (result.code === 802) setNeteaseStatus('已扫码，请在手机上确认登录…');
				if (result.code === 803 && result.cookie) {
					sessionStorage.setItem('jingyue-netease-cookie', result.cookie);
					setNeteaseStatus('登录成功，正在读取歌单…', 'success');
					await loadNeteaseAccount(result.cookie);
					ui.neteaseQrWrap.classList.add('hidden');
					ui.neteaseQrWrap.classList.remove('flex');
					return;
				}
				pollNeteaseQr(key);
			} catch (error) {
				setNeteaseStatus(error instanceof Error ? error.message : '二维码状态读取失败', 'error');
			}
		}, 1800);
	}

	async function startNeteaseLogin() {
		setNeteaseStatus('正在生成登录二维码…');
		try {
			var keyResult = await neteaseApi('/login/qr/key');
			var key = keyResult.data?.unikey || keyResult.unikey;
			if (!key) throw new Error('未能生成登录二维码');
			var qrResult = await neteaseApi('/login/qr/create', { key: key, qrimg: true });
			var qrImage = qrResult.data?.qrimg || qrResult.qrimg;
			if (!qrImage) throw new Error('接口没有返回二维码图片');
			ui.neteaseQr.src = qrImage;
			ui.neteaseQrWrap.classList.remove('hidden');
			ui.neteaseQrWrap.classList.add('flex');
			setNeteaseStatus('请使用网易云音乐 App 扫码登录');
			pollNeteaseQr(key);
		} catch (error) {
			setNeteaseStatus(error instanceof Error ? error.message : '二维码生成失败', 'error');
		}
	}

