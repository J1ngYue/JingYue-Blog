---
import { Icon } from "astro-icon/components";
import { musicPlayerConfig } from "@/config/musicConfig";

const libraryConfigStr = JSON.stringify({
	apiBaseUrl: musicPlayerConfig.neteaseSync?.apiBaseUrl ?? "",
	defaultPlaylistId:
		musicPlayerConfig.neteaseSync?.defaultPlaylistId ??
		musicPlayerConfig.meting?.id ??
		"",
	playlistLimit: musicPlayerConfig.neteaseSync?.playlistLimit ?? 50,
});
---

<dialog id="jingyue-music-library" class="music-library-dialog" aria-labelledby="music-library-title">
	<div class="music-library-shell">
		<header class="music-library-header">
			<div class="music-library-handle" aria-hidden="true"></div>
			<div class="music-library-heading">
				<div>
					<p>JINGYUE · MUSIC SPACE</p>
					<h2 id="music-library-title">音乐库</h2>
				</div>
				<button type="button" class="music-library-close" aria-label="关闭音乐库">
					<Icon is:inline name="material-symbols:close-rounded" />
				</button>
			</div>

			<nav class="music-library-tabs" aria-label="音乐库功能">
				<button type="button" data-music-tab="queue" class="is-active">
					<Icon is:inline name="material-symbols:queue-music-rounded" />
					<span>播放队列</span>
					<small data-queue-count>0</small>
				</button>
				<button type="button" data-music-tab="favorites">
					<Icon is:inline name="material-symbols:favorite-rounded" />
					<span>我的收藏</span>
					<small data-favorite-count>0</small>
				</button>
				<button type="button" data-music-tab="playlists">
					<Icon is:inline name="material-symbols:folder-rounded" />
					<span>我的歌单</span>
					<small data-playlist-count>0</small>
				</button>
				<button type="button" data-music-tab="search">
					<Icon is:inline name="material-symbols:search-rounded" />
					<span>在线搜索</span>
				</button>
				<button type="button" data-music-tab="import" class="music-library-import-tab">
					<Icon is:inline name="material-symbols:cloud-download-rounded" />
					<span>歌单导入</span>
				</button>
			</nav>
		</header>

		<div class="music-library-now" aria-live="polite">
			<div class="music-library-now-summary">
				<span class="music-library-now-dot" aria-hidden="true"></span>
				<span class="music-library-now-label">正在播放</span>
				<strong data-library-now-playing>暂无歌曲</strong>
				<small data-library-playback-state>等待播放</small>
			</div>
			<button
				type="button"
				class="music-library-now-toggle"
				data-library-now-toggle
				data-playing="false"
				aria-label="播放当前歌曲"
				disabled
			>
				<Icon is:inline class="music-library-now-play-icon" name="material-symbols:play-arrow-rounded" />
				<Icon is:inline class="music-library-now-pause-icon" name="material-symbols:pause-rounded" />
			</button>
		</div>

		<div class="music-library-content">
			<section data-music-panel="queue" class="music-library-panel is-active" aria-label="播放队列">
				<div class="music-library-section-title">
					<div>
						<h3>当前播放队列</h3>
						<p>点击歌曲即可切换播放，爱心会保存到当前浏览器。</p>
					</div>
				</div>
				<div class="music-library-track-list" data-queue-list></div>
			</section>

			<section data-music-panel="favorites" class="music-library-panel" aria-label="我的收藏">
				<div class="music-library-section-title">
					<div>
						<h3>我的收藏</h3>
						<p>收藏保存在本地浏览器，不会上传账号信息。</p>
					</div>
					<button type="button" class="music-library-soft-button" data-play-favorites>
						<Icon is:inline name="material-symbols:play-arrow-rounded" />
						播放全部
					</button>
				</div>
				<div class="music-library-track-list" data-favorite-list></div>
			</section>

			<section data-music-panel="playlists" class="music-library-panel" aria-label="我的歌单">
				<div class="music-library-section-title">
					<div>
						<h3>我的歌单</h3>
						<p>这里包含本地导入歌单，以及扫码后读取到的网易云歌单。</p>
					</div>
					<button type="button" class="music-library-soft-button" data-netease-login>
						<Icon is:inline name="material-symbols:qr-code-2-rounded" />
						扫码登录网易云
					</button>
				</div>

				<div class="music-library-login-note" data-login-note>
					<Icon is:inline name="material-symbols:shield-lock-rounded" />
					<span>登录需要配置自己的网易云兼容接口；Cookie 仅保存在本次浏览器会话。</span>
				</div>
				<div class="music-library-qr-card" data-qr-card hidden>
					<img data-qr-image alt="网易云登录二维码" />
					<div>
						<strong>使用网易云音乐 App 扫码</strong>
						<p data-qr-status>等待扫码…</p>
					</div>
				</div>
				<div class="music-library-playlist-grid" data-account-playlists></div>
				<div class="music-library-playlist-grid" data-saved-playlists></div>
				<div class="music-library-playlist-empty" data-playlist-empty hidden>
					<div class="music-library-playlist-empty-icon" aria-hidden="true">
						<Icon is:inline name="material-symbols:library-music-rounded" />
					</div>
					<div>
						<strong>还没有保存的歌单</strong>
						<p>输入网易云歌单 ID，或扫码同步后，歌单会出现在这里。</p>
					</div>
					<div class="music-library-playlist-empty-actions">
						<button type="button" class="music-library-soft-button" data-open-playlist-import>
							<Icon is:inline name="material-symbols:cloud-download-rounded" />
							导入歌单
						</button>
						<button type="button" class="music-library-soft-button" data-empty-netease-login>
							<Icon is:inline name="material-symbols:qr-code-2-rounded" />
							扫码同步
						</button>
					</div>
				</div>
			</section>

			<section data-music-panel="search" class="music-library-panel" aria-label="在线搜索">
				<div class="music-library-section-title">
					<div>
						<h3>在线搜索</h3>
						<p>搜索歌曲或歌手，结果可直接加入当前播放队列。</p>
					</div>
				</div>
				<form class="music-library-search-form" data-music-search-form>
					<label class="sr-only" for="music-library-search-input">搜索歌曲或歌手</label>
					<Icon is:inline name="material-symbols:search-rounded" />
					<input id="music-library-search-input" data-music-search-input type="search" placeholder="输入歌曲名、歌手名" autocomplete="off" />
					<button type="submit">搜索</button>
				</form>
				<p class="music-library-status" data-search-status aria-live="polite">输入关键词开始搜索。</p>
				<div class="music-library-track-list" data-search-list></div>
			</section>

			<section data-music-panel="import" class="music-library-panel" aria-label="歌单导入">
				<div class="music-library-import-guide">
					<strong>
						<Icon is:inline name="simple-icons:neteasecloudmusic" />
						网易云歌单导入教程
					</strong>
					<ol>
						<li>打开网易云音乐，进入要导入的公开歌单。</li>
						<li>复制分享链接中的数字 ID，粘贴到下方。</li>
						<li>选择新建歌单或加入已有歌单，再点击“一键导入”。</li>
					</ol>
				</div>

				<form data-playlist-import-form class="music-library-import-form">
					<div class="music-library-import-fields">
						<label>
							<span>网易云歌单 ID</span>
							<input data-import-id inputmode="numeric" pattern="[0-9]+" placeholder="例如：10046455237" />
						</label>
						<label>
							<span>歌单名称</span>
							<input data-import-name placeholder="留空则自动命名" />
						</label>
					</div>

					<p class="music-library-import-label">选择导入到哪个歌单文件夹</p>
					<details class="music-library-import-option" open>
						<summary>
							<span>
								<Icon is:inline name="material-symbols:create-new-folder-rounded" />
								自动创建新的歌单文件夹
							</span>
							<Icon is:inline name="material-symbols:keyboard-arrow-down-rounded" />
						</summary>
						<label class="music-library-option-body">
							<input type="radio" name="music-import-target" value="new" checked />
							<span>
								<strong>新建并保存到“我的歌单”</strong>
								<small>导入完成后可以离线查看歌单信息并一键载入。</small>
							</span>
						</label>
					</details>

					<details class="music-library-import-option">
						<summary>
							<span>
								<Icon is:inline name="material-symbols:folder-copy-rounded" />
								导入并添加到已有歌单
							</span>
							<Icon is:inline name="material-symbols:keyboard-arrow-down-rounded" />
						</summary>
						<div class="music-library-option-body">
							<input type="radio" name="music-import-target" value="existing" />
							<select data-import-existing aria-label="选择已有歌单"></select>
						</div>
					</details>

					<div class="music-library-import-actions">
						<p data-import-status aria-live="polite">导入的歌曲会立即成为当前播放队列。</p>
						<button type="submit" data-import-submit>
							<Icon is:inline name="material-symbols:cloud-download-rounded" />
							一键导入
						</button>
					</div>
				</form>
			</section>
		</div>
	</div>
</dialog>

<script is:inline data-swup-ignore-script define:vars={{ libraryConfigStr }}>
	(function initJingYueMusicLibrary() {
		if (window.__jingyueMusicLibraryInitialized) return;
		window.__jingyueMusicLibraryInitialized = true;

		var config = JSON.parse(libraryConfigStr);
		var dialog = document.getElementById('jingyue-music-library');
		if (!dialog) return;

		var FAVORITES_KEY = 'jingyue-music-favorites';
		var PLAYLISTS_KEY = 'jingyue-music-playlists';
		var qrPollTimer = 0;
		var searchResults = [];

		var ui = {
			close: dialog.querySelector('.music-library-close'),
			tabs: Array.from(dialog.querySelectorAll('[data-music-tab]')),
			panels: Array.from(dialog.querySelectorAll('[data-music-panel]')),
			nowPlaying: dialog.querySelector('[data-library-now-playing]'),
			playbackState: dialog.querySelector('[data-library-playback-state]'),
			nowToggle: dialog.querySelector('[data-library-now-toggle]'),
			queueCount: dialog.querySelector('[data-queue-count]'),
			favoriteCount: dialog.querySelector('[data-favorite-count]'),
			playlistCount: dialog.querySelector('[data-playlist-count]'),
			queueList: dialog.querySelector('[data-queue-list]'),
			favoriteList: dialog.querySelector('[data-favorite-list]'),
			savedPlaylists: dialog.querySelector('[data-saved-playlists]'),
			accountPlaylists: dialog.querySelector('[data-account-playlists]'),
			playlistEmpty: dialog.querySelector('[data-playlist-empty]'),
			playFavorites: dialog.querySelector('[data-play-favorites]'),
			searchForm: dialog.querySelector('[data-music-search-form]'),
			searchInput: dialog.querySelector('[data-music-search-input]'),
			searchStatus: dialog.querySelector('[data-search-status]'),
			searchList: dialog.querySelector('[data-search-list]'),
			login: dialog.querySelector('[data-netease-login]'),
			loginNote: dialog.querySelector('[data-login-note]'),
			qrCard: dialog.querySelector('[data-qr-card]'),
			qrImage: dialog.querySelector('[data-qr-image]'),
			qrStatus: dialog.querySelector('[data-qr-status]'),
			importForm: dialog.querySelector('[data-playlist-import-form]'),
			importId: dialog.querySelector('[data-import-id]'),
			importName: dialog.querySelector('[data-import-name]'),
			importExisting: dialog.querySelector('[data-import-existing]'),
			importStatus: dialog.querySelector('[data-import-status]'),
			importSubmit: dialog.querySelector('[data-import-submit]'),
			openPlaylistImport: dialog.querySelector('[data-open-playlist-import]'),
			emptyNeteaseLogin: dialog.querySelector('[data-empty-netease-login]')
		};

		function getManager() {
			return window.__fireflyMusic || null;
		}

		function readStorage(key, fallback) {
			try {
				var value = JSON.parse(localStorage.getItem(key) || 'null');
				return Array.isArray(value) ? value : fallback;
			} catch {
				return fallback;
			}
		}

		function writeStorage(key, value) {
			try {
				localStorage.setItem(key, JSON.stringify(value));
				return true;
			} catch {
				return false;
			}
		}

		function trackKey(track) {
			return track.url || (track.name + '::' + track.artist);
		}

		function getFavorites() {
			return readStorage(FAVORITES_KEY, []);
		}

		function getPlaylists() {
			return readStorage(PLAYLISTS_KEY, []);
		}

		function isFavorite(track) {
			var key = trackKey(track);
			return getFavorites().some(function (item) { return trackKey(item) === key; });
		}

		function toggleFavorite(track) {
			var favorites = getFavorites();
			var key = trackKey(track);
			var index = favorites.findIndex(function (item) { return trackKey(item) === key; });
			if (index >= 0) favorites.splice(index, 1);
			else favorites.unshift(track);
			writeStorage(FAVORITES_KEY, favorites);
			renderAll();
		}

		function emptyState(text) {
			var empty = document.createElement('div');
			empty.className = 'music-library-empty';
			empty.textContent = text;
			return empty;
		}

		function renderTrackList(container, tracks, playFromCollection) {
			container.replaceChildren();
			if (!tracks.length) {
				container.appendChild(emptyState('这里还没有歌曲。'));
				return;
			}

			var manager = getManager();
			var state = manager?.getState();
			var currentKey = state?.track ? trackKey(state.track) : '';

			tracks.forEach(function (track, index) {
				var row = document.createElement('div');
				row.className = 'music-library-track';
				var isCurrent = currentKey === trackKey(track);
				var isPlaying = isCurrent && Boolean(state?.isPlaying);
				row.classList.toggle('is-current', isCurrent);
				row.classList.toggle('is-playing', isPlaying);

				var play = document.createElement('button');
				play.type = 'button';
				play.className = 'music-library-track-main';
				play.setAttribute('aria-label', (isPlaying ? '暂停 ' : '播放 ') + track.name);
				play.setAttribute('aria-pressed', String(isPlaying));
				play.addEventListener('click', function () {
					var manager = getManager();
					if (!manager) return;
					var current = manager.getState().track;
					if (current && trackKey(current) === trackKey(track)) manager.togglePlay();
					else if (playFromCollection) manager.replacePlaylist(tracks, index, true);
					else manager.playTrackByIndex(index);
				});

				var cover = document.createElement(track.pic ? 'img' : 'span');
				cover.className = 'music-library-track-cover';
				if (track.pic) {
					cover.src = track.pic;
					cover.alt = '';
					cover.loading = 'lazy';
				} else {
					cover.textContent = '♫';
				}

				var copy = document.createElement('span');
				copy.className = 'music-library-track-copy';
				var title = document.createElement('strong');
				title.textContent = track.name;
				var artist = document.createElement('small');
				artist.textContent = track.artist || '未知歌手';
				copy.append(title, artist);
				if (isCurrent) {
					var status = document.createElement('em');
					status.className = 'music-library-track-status';
					status.textContent = isPlaying ? '播放中' : '已暂停';
					copy.appendChild(status);
				}

				var icon = document.createElement('span');
				icon.className = 'music-library-track-play';
				icon.setAttribute('aria-hidden', 'true');
				play.append(cover, copy, icon);

				var favorite = document.createElement('button');
				favorite.type = 'button';
				favorite.className = 'music-library-favorite-button';
				favorite.classList.toggle('is-favorite', isFavorite(track));
				favorite.textContent = isFavorite(track) ? '♥' : '♡';
				favorite.setAttribute('aria-label', isFavorite(track) ? '取消收藏' : '收藏歌曲');
				favorite.addEventListener('click', function () { toggleFavorite(track); });
				row.append(play, favorite);
				container.appendChild(row);
			});
		}

		function renderPlaylistCards(container, playlists, accountMode) {
			container.replaceChildren();
			if (!playlists.length) {
				return;
			}

			playlists.forEach(function (playlist) {
				var card = document.createElement('article');
				card.className = 'music-library-playlist-card';
				var icon = document.createElement('span');
				icon.className = 'music-library-playlist-icon';
				icon.textContent = accountMode ? '☁' : '♫';
				var copy = document.createElement('div');
				var name = document.createElement('strong');
				name.textContent = playlist.name || ('网易云歌单 ' + playlist.id);
				var meta = document.createElement('small');
				meta.textContent = (playlist.trackCount ?? playlist.tracks?.length ?? 0) + ' 首歌曲';
				copy.append(name, meta);

				var play = document.createElement('button');
				play.type = 'button';
				play.textContent = accountMode ? '同步' : '载入';
				play.addEventListener('click', async function () {
					if (accountMode) {
						await importPlaylist(String(playlist.id), playlist.name, true);
						return;
					}
					getManager()?.replacePlaylist(playlist.tracks || [], 0, false);
				});
				card.append(icon, copy, play);

				if (!accountMode) {
					var remove = document.createElement('button');
					remove.type = 'button';
					remove.className = 'music-library-playlist-remove';
					remove.textContent = '×';
					remove.setAttribute('aria-label', '删除歌单');
					remove.addEventListener('click', function () {
						writeStorage(PLAYLISTS_KEY, getPlaylists().filter(function (item) {
							return item.id !== playlist.id;
						}));
						renderAll();
					});
					card.appendChild(remove);
				}
				container.appendChild(card);
			});
		}

		function renderImportTargets(playlists) {
			ui.importExisting.replaceChildren();
			if (!playlists.length) {
				var empty = document.createElement('option');
				empty.value = '';
				empty.textContent = '暂无已有歌单';
				ui.importExisting.appendChild(empty);
				return;
			}
			playlists.forEach(function (playlist) {
				var option = document.createElement('option');
				option.value = playlist.id;
				option.textContent = playlist.name;
				ui.importExisting.appendChild(option);
			});
		}

		function renderAll() {
			var manager = getManager();
			var state = manager?.getState();
			var queue = state?.playlist || [];
			var favorites = getFavorites();
			var playlists = getPlaylists();
			ui.nowPlaying.textContent = state?.track
				? state.track.name + ' · ' + state.track.artist
				: '暂无歌曲';
			ui.playbackState.textContent = state?.track
				? state.isPlaying ? '播放中' : '已暂停'
				: '等待播放';
			ui.nowToggle.disabled = !state?.track;
			ui.nowToggle.dataset.playing = String(Boolean(state?.isPlaying));
			ui.nowToggle.setAttribute(
				'aria-label',
				state?.isPlaying ? '暂停当前歌曲' : '播放当前歌曲'
			);
			ui.queueCount.textContent = String(queue.length);
			ui.favoriteCount.textContent = String(favorites.length);
			ui.playlistCount.textContent = String(playlists.length);
			renderTrackList(ui.queueList, queue, false);
			renderTrackList(ui.favoriteList, favorites, true);
			renderPlaylistCards(ui.savedPlaylists, playlists, false);
			ui.playlistEmpty.hidden = playlists.length > 0;
			renderImportTargets(playlists);
			if (searchResults.length) renderTrackList(ui.searchList, searchResults, true);
		}

		function switchTab(key) {
			ui.tabs.forEach(function (tab) {
				var active = tab.dataset.musicTab === key;
				tab.classList.toggle('is-active', active);
				tab.setAttribute('aria-selected', String(active));
			});
			ui.panels.forEach(function (panel) {
				panel.classList.toggle('is-active', panel.dataset.musicPanel === key);
			});
		}

		async function importPlaylist(playlistId, playlistName, playImmediately) {
			var manager = getManager();
			if (!manager) throw new Error('播放器尚未就绪');
			var id = String(playlistId || '').trim();
			if (!/^\d+$/.test(id)) throw new Error('请输入正确的数字歌单 ID');
			ui.importStatus.dataset.state = 'loading';
			ui.importSubmit.disabled = true;
			ui.importStatus.textContent = '正在读取网易云歌单…';
			await manager.syncMetingPlaylist(id);
			var tracks = manager.getState().playlist;
			var playlists = getPlaylists();
			var selectedTarget = dialog.querySelector('input[name="music-import-target"]:checked')?.value;
			var targetId = selectedTarget === 'existing' ? ui.importExisting.value : '';
			var target = playlists.find(function (item) { return item.id === targetId; });

			if (target) {
				var existing = new Set((target.tracks || []).map(trackKey));
				target.tracks = (target.tracks || []).concat(tracks.filter(function (track) {
					return !existing.has(trackKey(track));
				}));
				target.trackCount = target.tracks.length;
			} else {
				playlists.unshift({
					id: 'local-' + Date.now(),
					sourceId: id,
					name: playlistName || ('网易云歌单 ' + id),
					trackCount: tracks.length,
					tracks: tracks,
					createdAt: new Date().toISOString()
				});
			}

			if (!writeStorage(PLAYLISTS_KEY, playlists)) {
				throw new Error('浏览器存储空间不足，歌单已播放但未能保存');
			}
			ui.importStatus.textContent = '导入完成，共 ' + tracks.length + ' 首歌曲。';
			ui.importStatus.dataset.state = 'success';
			renderAll();
			if (playImmediately) manager.loadTrack(0, false);
		}

		async function neteaseApi(path, params) {
			var base = String(config.apiBaseUrl || '').replace(/\/$/, '');
			if (!base) throw new Error('请先配置 PUBLIC_NETEASE_API_BASE_URL');
			var requestUrl = new URL(base + path);
			Object.keys(params || {}).forEach(function (key) {
				if (params[key] !== undefined && params[key] !== '') {
					requestUrl.searchParams.set(key, String(params[key]));
				}
			});
			requestUrl.searchParams.set('timestamp', String(Date.now()));
			var response = await fetch(requestUrl);
			if (!response.ok) throw new Error('接口请求失败（' + response.status + '）');
			return response.json();
		}

		async function loadAccountPlaylists(cookie) {
			var loginStatus = await neteaseApi('/login/status', { cookie: cookie });
			var profile = loginStatus.data?.profile || loginStatus.profile;
			var userId = profile?.userId || loginStatus.data?.account?.id || loginStatus.account?.id;
			if (!userId) throw new Error('未读取到网易云用户信息');
			var result = await neteaseApi('/user/playlist', {
				uid: userId,
				limit: config.playlistLimit || 50,
				cookie: cookie
			});
			var playlists = Array.isArray(result.playlist) ? result.playlist : [];
			renderPlaylistCards(ui.accountPlaylists, playlists, true);
			ui.qrStatus.textContent = '登录成功，已读取 ' + playlists.length + ' 个歌单。';
		}

		function pollQr(key) {
			if (qrPollTimer) window.clearTimeout(qrPollTimer);
			qrPollTimer = window.setTimeout(async function check() {
				try {
					var result = await neteaseApi('/login/qr/check', { key: key });
					if (result.code === 800) {
						ui.qrStatus.textContent = '二维码已过期，请重新生成。';
						return;
					}
					if (result.code === 802) ui.qrStatus.textContent = '已扫码，请在手机上确认登录…';
					if (result.code === 803 && result.cookie) {
						sessionStorage.setItem('jingyue-netease-cookie', result.cookie);
						await loadAccountPlaylists(result.cookie);
						return;
					}
					pollQr(key);
				} catch (error) {
					ui.qrStatus.textContent = error instanceof Error ? error.message : '登录状态读取失败';
				}
			}, 1800);
		}

		async function startQrLogin() {
			if (!config.apiBaseUrl) {
				ui.loginNote.classList.add('is-error');
				ui.loginNote.querySelector('span').textContent =
					'请先在 .env 中配置 PUBLIC_NETEASE_API_BASE_URL，再使用扫码登录。';
				return;
			}
			try {
				var keyResult = await neteaseApi('/login/qr/key');
				var key = keyResult.data?.unikey || keyResult.unikey;
				if (!key) throw new Error('未能生成登录二维码');
				var qrResult = await neteaseApi('/login/qr/create', { key: key, qrimg: true });
				var qrImage = qrResult.data?.qrimg || qrResult.qrimg;
				if (!qrImage) throw new Error('接口没有返回二维码图片');
				ui.qrImage.src = qrImage;
				ui.qrCard.hidden = false;
				ui.qrStatus.textContent = '请使用网易云音乐 App 扫码。';
				pollQr(key);
			} catch (error) {
				ui.loginNote.classList.add('is-error');
				ui.loginNote.querySelector('span').textContent =
					error instanceof Error ? error.message : '二维码生成失败';
			}
		}

		ui.tabs.forEach(function (tab) {
			tab.addEventListener('click', function () { switchTab(tab.dataset.musicTab); });
		});
		ui.close.addEventListener('click', function () { dialog.close(); });
		dialog.addEventListener('click', function (event) {
			if (event.target === dialog) dialog.close();
		});
		dialog.addEventListener('close', function () {
			if (qrPollTimer) window.clearTimeout(qrPollTimer);
		});
		ui.playFavorites.addEventListener('click', function () {
			var favorites = getFavorites();
			if (favorites.length) getManager()?.replacePlaylist(favorites, 0, true);
		});
		ui.searchForm.addEventListener('submit', async function (event) {
			event.preventDefault();
			var keyword = ui.searchInput.value.trim();
			if (!keyword) return;
			ui.searchStatus.textContent = '正在搜索…';
			try {
				searchResults = await getManager().searchMetingTracks(keyword);
				ui.searchStatus.textContent = '找到 ' + searchResults.length + ' 首歌曲。';
				renderTrackList(ui.searchList, searchResults, true);
			} catch (error) {
				ui.searchStatus.textContent = error instanceof Error ? error.message : '搜索失败';
			}
		});
		ui.login.addEventListener('click', startQrLogin);
		ui.nowToggle.addEventListener('click', function () {
			getManager()?.togglePlay();
		});
		ui.openPlaylistImport.addEventListener('click', function () {
			switchTab('import');
			ui.importId.focus();
		});
		ui.emptyNeteaseLogin.addEventListener('click', function () {
			switchTab('playlists');
			startQrLogin();
		});
		ui.importForm.addEventListener('submit', async function (event) {
			event.preventDefault();
			try {
				await importPlaylist(ui.importId.value, ui.importName.value.trim(), false);
			} catch (error) {
				ui.importStatus.dataset.state = 'error';
				ui.importStatus.textContent = error instanceof Error ? error.message : '导入失败';
			}
			finally {
				ui.importSubmit.disabled = false;
			}
		});

		window.addEventListener('jingyue:open-music-library', function (event) {
			var targetTab = event.detail?.tab || 'queue';
			renderAll();
			switchTab(targetTab);
			if (!dialog.open) dialog.showModal();
		});
		['fm:init', 'fm:track', 'fm:play-state'].forEach(function (eventName) {
			window.addEventListener(eventName, function () {
				if (dialog.open) renderAll();
			});
		});

		var cachedCookie = sessionStorage.getItem('jingyue-netease-cookie');
		if (cachedCookie && config.apiBaseUrl) {
			loadAccountPlaylists(cachedCookie).catch(function () {
				sessionStorage.removeItem('jingyue-netease-cookie');
			});
		}
	})();
</script>

