---
import MessageBox from "@/components/common/PioMessageBox.astro";
import { characterModelCatalog, spineModelConfig } from "@/config/pioConfig";
import { url } from "@/utils/url-utils";
---

<div
  id="character-model-switcher"
  data-character-model-switcher
  style="position: fixed; left: 9.25rem; top: calc(100dvh - 4.25rem); z-index: 2147483000; pointer-events: none;"
>
  <div class="character-model-hover-card" data-character-model-hover-card>
    <strong data-character-model-hover-label>萤火虫</strong>
    <div class="character-model-hover-actions">
      <button type="button" data-character-action="switch" title="选择角色">切换模型</button>
      <button type="button" data-character-action="sleep" aria-pressed="false" title="暂停或唤醒模型">
        <span data-character-sleep-label>休眠</span>
      </button>
    </div>
  </div>
  <button
    type="button"
    class="character-model-wake-tab"
    data-character-wake
    aria-label="唤醒宠物"
    title="唤醒宠物"
    hidden
  >
    <span aria-hidden="true">Zzz</span>
    <strong>唤醒</strong>
  </button>
  <button
    type="button"
    class="character-model-backdrop"
    data-character-model-backdrop
    aria-label="关闭角色选择面板"
    hidden
  ></button>
  <div
    id="character-model-options"
    data-character-model-options
    hidden
    role="menu"
    aria-label="角色选择面板"
    class="character-model-library"
  >
    <div class="character-model-library-header" role="presentation">
      <span>选择角色</span>
      <small>{characterModelCatalog.length} 个模型 · 拖动角色可调整位置</small>
    </div>
    <div class="character-model-grid" role="presentation">
      {characterModelCatalog.map((item) => (
        <button
          type="button"
          role="menuitemradio"
          aria-checked={item.id === "firefly" ? "true" : "false"}
          data-character-model-option={item.id}
          data-character-model-type={item.type}
          class="character-model-option"
        >
          <span class="character-model-option-preview" aria-hidden="true">
            <span>{item.type === "spine" ? "SP" : item.type === "sprite" ? "PX" : "L2"}</span>
            {item.type === "sprite" ? (
              <span
                class="character-model-sprite-preview"
                style={`background-image: url('${item.preview}')`}
              ></span>
            ) : (
              <img src={item.preview} alt="" loading="lazy" decoding="async" />
            )}
          </span>
          <span class="character-model-option-copy">
            <strong>{item.label}</strong>
            <small>{item.description}</small>
            <em>{item.type === "spine" ? "Spine" : item.type === "sprite" ? "像素宠物" : "Live2D"}</em>
          </span>
          <span class="character-model-selected" aria-hidden="true">使用中</span>
        </button>
      ))}
    </div>
  </div>
</div>

<!-- Spine Web Player CSS 将在 script 中动态加载 -->{
  spineModelConfig.enable && (
    <div
      id="spine-model-container"
      style={`
      position: fixed;
      ${spineModelConfig.position.corner.includes("right") ? "right" : "left"}: ${spineModelConfig.position.offsetX}px;
      ${spineModelConfig.position.corner.includes("top") ? "top" : "bottom"}: ${spineModelConfig.position.offsetY}px;
      width: ${spineModelConfig.size.width}px;
      height: ${spineModelConfig.size.height}px;
      pointer-events: auto;
      z-index: 1000;
    `}
    >
      <div id="spine-player-container" style="width: 100%; height: 100%;" />
      <div id="spine-error" style="display: none;" />
    </div>
  )
}

<div
  id="sprite-model-container"
  data-character-model-runtime="sprite"
  style="position: fixed; left: 8px; bottom: 8px; width: 154px; height: 166px; display: none; pointer-events: auto; z-index: 1000;"
>
  <div id="sprite-model" aria-label="像素宠物"></div>
  <div class="sprite-model-reaction" aria-hidden="true">
    <span>♥</span>
    <span>✦</span>
    <span>♥</span>
  </div>
</div>

<!-- 引入消息框组件 -->
<MessageBox />

<script is:inline define:vars={{ characterModelCatalog, spineModelConfig, modelPath: url(spineModelConfig.model.path), atlasPath: url(spineModelConfig.model.path.replace(".json", ".atlas")), cssPath: url("/pio/static/spine-player.min.css"), jsPath: url("/pio/static/spine-player.min.js") }}>
  const CHARACTER_MODEL_KEY = "fireflyCharacterModel";
  const CHARACTER_POSITION_KEY = "fireflyCharacterPosition";
  const CHARACTER_SLEEP_KEY = "fireflyCharacterSleeping";
  const CHARACTER_MODEL_LABELS = Object.fromEntries(
    characterModelCatalog.map((item) => [item.id, item.label]),
  );
  const CHARACTER_MODEL_LIVE2D_INDEXES = Object.fromEntries(
    characterModelCatalog
      .filter((item) => item.type === "live2d")
      .map((item) => [item.id, item.live2dIndex]),
  );
  const CHARACTER_MODEL_TYPES = Object.fromEntries(
    characterModelCatalog.map((item) => [item.id, item.type]),
  );
  const CHARACTER_MODELS = Object.keys(CHARACTER_MODEL_LABELS);

  function getSelectedCharacterModel() {
    const stored = localStorage.getItem(CHARACTER_MODEL_KEY);
    return CHARACTER_MODELS.includes(stored) ? stored : "firefly";
  }

  function getStoredCharacterPosition() {
    try {
      const stored = JSON.parse(localStorage.getItem(CHARACTER_POSITION_KEY) || "null");
      if (Number.isFinite(stored?.x) && Number.isFinite(stored?.bottom)) {
        return { x: stored.x, bottom: stored.bottom };
      }
    } catch (_error) {
      // Ignore malformed values and fall back to the safe corner position.
    }
    return { x: 8, bottom: 8 };
  }

  let characterPosition = getStoredCharacterPosition();
  let characterLayoutFrame = 0;
  let suppressCharacterClick = false;
  let activeCharacterDragCleanup = null;
  let characterInteractionTimer = 0;
  let characterSleeping = localStorage.getItem(CHARACTER_SLEEP_KEY) === "true";
  let characterHoverTimer = 0;

  function getActiveCharacterRuntime() {
    const model = getSelectedCharacterModel();
    if (model === "firefly") return document.getElementById("spine-model-container");
    if (CHARACTER_MODEL_TYPES[model] === "sprite") {
      return document.getElementById("sprite-model-container");
    }
    return document.getElementById("firefly-live2d-runtime");
  }

  function clampCharacterPosition(position, runtime = getActiveCharacterRuntime()) {
    const model = getSelectedCharacterModel();
    const runtimeWidth = runtime?.offsetWidth || (model === "firefly" ? 135 : model === "totoro" || model === "gugugaga" || model === "feibi" || model === "nailong" ? 154 : 200);
    const runtimeHeight = runtime?.offsetHeight || (model === "firefly" ? 165 : model === "totoro" || model === "gugugaga" || model === "feibi" || model === "nailong" ? 166 : 200);
    const safeTopSpace = 84;
    return {
      x: Math.min(Math.max(8, position.x), Math.max(8, window.innerWidth - runtimeWidth - 8)),
      bottom: Math.min(
        Math.max(8, position.bottom),
        Math.max(8, window.innerHeight - runtimeHeight - safeTopSpace),
      ),
    };
  }

  function positionCharacterLibrary() {
    const switcher = document.querySelector("[data-character-model-switcher]");
    const panel = switcher?.querySelector("[data-character-model-options]");
    if (!panel || panel.hidden) return;
    panel.style.left = "50%";
    panel.style.top = "50%";
  }

  function layoutCharacterControls() {
    if (characterLayoutFrame) cancelAnimationFrame(characterLayoutFrame);
    characterLayoutFrame = requestAnimationFrame(() => {
      characterLayoutFrame = 0;
      const switcher = document.querySelector("[data-character-model-switcher]");
      const card = switcher?.querySelector("[data-character-model-hover-card]");
      const runtime = getActiveCharacterRuntime();
      if (!switcher || !card || !runtime || runtime.style.display === "none") return;

      const runtimeRect = runtime.getBoundingClientRect();
      const cardRect = card.getBoundingClientRect();
      const gap = 10;
      const padding = 8;
      const cardWidth = cardRect.width || 190;
      const cardHeight = cardRect.height || 76;
      let left = runtimeRect.left + (runtimeRect.width - cardWidth) / 2;
      let top = runtimeRect.top - cardHeight - gap;

      if (top < padding) top = runtimeRect.bottom + gap;
      if (top + cardHeight > window.innerHeight - padding) {
        top = Math.max(padding, window.innerHeight - cardHeight - padding);
      }
      left = Math.min(Math.max(padding, left), Math.max(padding, window.innerWidth - cardWidth - padding));

      switcher.style.left = `${left}px`;
      switcher.style.top = `${top}px`;
      positionCharacterLibrary();
    });
  }

  function applyCharacterPosition(nextPosition = characterPosition, persist = false) {
    const activeRuntime = getActiveCharacterRuntime();
    characterPosition = clampCharacterPosition(nextPosition, activeRuntime);
    [
      document.getElementById("spine-model-container"),
      document.getElementById("sprite-model-container"),
      document.getElementById("firefly-live2d-runtime"),
    ].forEach((runtime) => {
      if (!runtime) return;
      runtime.style.left = `${characterPosition.x}px`;
      runtime.style.right = "auto";
      runtime.style.bottom = `${characterPosition.bottom}px`;
      runtime.style.top = "auto";
    });
    if (persist) {
      localStorage.setItem(CHARACTER_POSITION_KEY, JSON.stringify(characterPosition));
    }
    layoutCharacterControls();
  }

  function playCharacterClickFeedback(runtime) {
    if (!runtime || characterSleeping) return;
    const model = getSelectedCharacterModel();
    const modelType = CHARACTER_MODEL_TYPES[model];

    if (modelType === "sprite") {
      window.clearTimeout(characterInteractionTimer);
      runtime.classList.remove("is-character-interacting");
      void runtime.offsetWidth;
      runtime.classList.add("is-character-interacting");
      characterInteractionTimer = window.setTimeout(() => {
        runtime.classList.remove("is-character-interacting");
      }, 760);
    } else if (modelType === "spine") {
      window.__fireflySpineInteract?.();
    } else if (modelType === "live2d") {
      window.dispatchEvent(
        new CustomEvent("firefly:character-interact", {
          detail: { model, type: modelType },
        }),
      );
    }

    if (modelType === "sprite") {
      const messages = spineModelConfig.interactive.clickMessages || [];
      const message = messages[Math.floor(Math.random() * messages.length)];
      if (message) {
        window.showModelMessage?.(message, {
          containerId: runtime.id,
          displayTime: Math.min(2200, spineModelConfig.interactive.messageDisplayTime || 2200),
        });
      }
    }
  }

  function attachCharacterDragHandle(element) {
    if (!element || element.dataset.characterDragReady === "true") return;
    element.dataset.characterDragReady = "true";
    element.style.touchAction = "none";
    element.addEventListener("pointerdown", (event) => {
      if (event.button !== 0 || event.isPrimary === false) return;
      activeCharacterDragCleanup?.();
      const start = { ...characterPosition };
      const startX = event.clientX;
      const startY = event.clientY;
      let moved = false;
      let finished = false;
      const pointerId = event.pointerId;
      try {
        element.setPointerCapture?.(pointerId);
      } catch (_error) {
        // Window-level listeners below still guarantee a clean drag session.
      }

      const handleMove = (moveEvent) => {
        const deltaX = moveEvent.clientX - startX;
        const deltaY = moveEvent.clientY - startY;
        if (!moved && Math.hypot(deltaX, deltaY) < 5) return;
        moved = true;
        suppressCharacterClick = true;
        window.clearModelMessage?.();
        applyCharacterPosition(
          { x: start.x + deltaX, bottom: start.bottom - deltaY },
          false,
        );
        moveEvent.preventDefault();
      };

      const handleEnd = (endEvent) => {
        if (endEvent?.pointerId !== undefined && endEvent.pointerId !== pointerId) return;
        if (finished) return;
        finished = true;
        window.removeEventListener("pointermove", handleMove);
        window.removeEventListener("pointerup", handleEnd);
        window.removeEventListener("pointercancel", handleEnd);
        window.removeEventListener("blur", handleEnd);
        element.removeEventListener("lostpointercapture", handleEnd);
        try {
          if (element.hasPointerCapture?.(pointerId)) element.releasePointerCapture(pointerId);
        } catch (_error) {
          // The pointer may already have been released by the browser.
        }
        activeCharacterDragCleanup = null;
        if (moved) {
          localStorage.setItem(CHARACTER_POSITION_KEY, JSON.stringify(characterPosition));
          window.setTimeout(() => {
            suppressCharacterClick = false;
          }, 180);
        } else if (characterSleeping) {
          setCharacterSleeping(false);
        } else {
          playCharacterClickFeedback(getActiveCharacterRuntime());
        }
      };

      activeCharacterDragCleanup = () => handleEnd();
      window.addEventListener("pointermove", handleMove, { passive: false });
      window.addEventListener("pointerup", handleEnd);
      window.addEventListener("pointercancel", handleEnd);
      window.addEventListener("blur", handleEnd);
      element.addEventListener("lostpointercapture", handleEnd);
    });
  }

  function attachCharacterRuntime(runtime) {
    if (!runtime) return;
    applyCharacterPosition(characterPosition);
    attachCharacterDragHandle(runtime.querySelector("canvas") || runtime);
    attachCharacterHoverReveal(runtime);
    runtime.classList.toggle("is-character-sleeping", characterSleeping);
    if (getSelectedCharacterModel() === "firefly" && window.spinePlayerInstance) {
      if (characterSleeping) window.spinePlayerInstance.pause?.();
      else window.spinePlayerInstance.play?.();
    }
  }

  function setCharacterHoverState(hovered) {
    const switcher = document.querySelector("[data-character-model-switcher]");
    if (!switcher) return;
    window.clearTimeout(characterHoverTimer);
    if (hovered) {
      switcher.dataset.petHovered = "true";
      switcher.style.pointerEvents = "auto";
      return;
    }
    characterHoverTimer = window.setTimeout(() => {
      delete switcher.dataset.petHovered;
      if (
        !characterSleeping &&
        document.querySelector("[data-character-model-options]")?.hidden !== false
      ) {
        switcher.style.pointerEvents = "none";
      }
    }, 550);
  }

  function attachCharacterHoverReveal(runtime) {
    if (!runtime || runtime.dataset.characterHoverReady === "true") return;
    runtime.dataset.characterHoverReady = "true";
    runtime.addEventListener("pointerenter", () => setCharacterHoverState(true));
    runtime.addEventListener("pointerleave", () => setCharacterHoverState(false));
  }

  function updateCharacterSleepUI() {
    const switcher = document.querySelector("[data-character-model-switcher]");
    const button = switcher?.querySelector("[data-character-action='sleep']");
    const label = switcher?.querySelector("[data-character-sleep-label]");
    const wakeTab = switcher?.querySelector("[data-character-wake]");
    const sleeping = characterSleeping;
    if (button) {
      button.setAttribute("aria-pressed", String(sleeping));
      button.setAttribute("title", sleeping ? "唤醒模型" : "暂停或唤醒模型");
    }
    if (label) label.textContent = sleeping ? "唤醒" : "休眠";
    if (wakeTab) wakeTab.hidden = !sleeping;
    if (switcher) {
      switcher.dataset.petSleeping = String(sleeping);
      if (sleeping) switcher.style.pointerEvents = "auto";
      else if (
        switcher.dataset.petHovered !== "true" &&
        switcher.dataset.libraryOpen !== "true"
      ) {
        switcher.style.pointerEvents = "none";
      }
    }
    document.documentElement.dataset.characterSleeping = String(sleeping);
    document.querySelectorAll("#spine-model-container, #sprite-model-container, #firefly-live2d-runtime").forEach((runtime) => {
      runtime.classList.toggle("is-character-sleeping", sleeping);
    });
    applyCharacterPosition(characterPosition);
  }

  function setCharacterSleeping(nextSleeping, persist = true) {
    characterSleeping = Boolean(nextSleeping);
    if (persist) localStorage.setItem(CHARACTER_SLEEP_KEY, String(characterSleeping));
    const player = window.spinePlayerInstance;
    if (getSelectedCharacterModel() === "firefly" && player) {
      if (characterSleeping) player.pause?.();
      else player.play?.();
    }
    updateCharacterSleepUI();
    window.dispatchEvent(
      new CustomEvent("firefly:character-sleep-change", {
        detail: { sleeping: characterSleeping },
      }),
    );
  }

  function updateCharacterModelUI(model) {
    document.documentElement.dataset.characterModel = model;
    const switcher = document.querySelector("[data-character-model-switcher]");
    const hoverLabel = switcher?.querySelector("[data-character-model-hover-label]");
    const options = switcher?.querySelectorAll("[data-character-model-option]") || [];
    if (hoverLabel) hoverLabel.textContent = CHARACTER_MODEL_LABELS[model];
    options.forEach((option) => {
      const active = option.dataset.characterModelOption === model;
      option.setAttribute("aria-checked", String(active));
    });

    const spineContainer = document.getElementById("spine-model-container");
    const spriteContainer = document.getElementById("sprite-model-container");
    const sprite = document.getElementById("sprite-model");
    const modelType = CHARACTER_MODEL_TYPES[model];
    if (spineContainer) {
      spineContainer.style.display = modelType === "spine" ? "block" : "none";
    }
    if (spriteContainer) {
      spriteContainer.style.display = modelType === "sprite" ? "block" : "none";
    }
    if (sprite) {
      const item = characterModelCatalog.find((entry) => entry.id === model);
      sprite.style.backgroundImage = item?.type === "sprite" ? `url('${item.sprite}')` : "none";
      sprite.dataset.spriteModel = item?.type === "sprite" ? item.id : "";
    }
    layoutCharacterControls();
    updateCharacterSleepUI();
  }

  function selectCharacterModel(model, notify = true) {
    if (!CHARACTER_MODELS.includes(model)) return;
    localStorage.setItem(CHARACTER_MODEL_KEY, model);
    updateCharacterModelUI(model);
    if (notify) {
      window.dispatchEvent(
        new CustomEvent("firefly:character-model-change", {
          detail: {
            model,
            type: CHARACTER_MODEL_TYPES[model],
            live2dIndex: CHARACTER_MODEL_LIVE2D_INDEXES[model] ?? 0,
          },
        }),
      );
    }
  }

  function initCharacterModelSwitcher() {
    const switcher = document.querySelector("[data-character-model-switcher]");
    if (!switcher) return;
    if (switcher.parentElement !== document.body) {
      document.body.appendChild(switcher);
    }
    const optionsPanel = switcher.querySelector("[data-character-model-options]");
    const backdrop = switcher.querySelector("[data-character-model-backdrop]");
    const options = Array.from(switcher.querySelectorAll("[data-character-model-option]"));
    const switchAction = switcher.querySelector("[data-character-action='switch']");
    const sleepAction = switcher.querySelector("[data-character-action='sleep']");
    const wakeAction = switcher.querySelector("[data-character-wake]");
    if (!optionsPanel || !backdrop) return;

    window.__fireflyCharacterModelAbort?.abort();
    const controller = new AbortController();
    window.__fireflyCharacterModelAbort = controller;
    const listenerOptions = { signal: controller.signal };
    let scrollLockEnabled = false;
    let lockedScrollY = window.scrollY;
    const restoreLockedScroll = () => {
      if (scrollLockEnabled && window.scrollY !== lockedScrollY) {
        window.scrollTo({ top: lockedScrollY, left: 0, behavior: "instant" });
      }
    };

    const setOpen = (open) => {
      if (open) lockedScrollY = window.scrollY;
      scrollLockEnabled = open;
      optionsPanel.hidden = !open;
      backdrop.hidden = !open;
      if (open) {
        switcher.style.pointerEvents = "auto";
        switcher.dataset.libraryOpen = "true";
      } else {
        delete switcher.dataset.petHovered;
        delete switcher.dataset.libraryOpen;
        switcher.style.pointerEvents = "none";
      }
      document.documentElement.classList.toggle("character-model-library-open", open);
      document.body.classList.toggle("character-model-library-open", open);
      if (open) {
        requestAnimationFrame(() => {
          positionCharacterLibrary();
          options.find((option) => option.getAttribute("aria-checked") === "true")?.focus({ preventScroll: true });
        });
      }
    };

    attachCharacterRuntime(document.getElementById("spine-model-container"));
    attachCharacterRuntime(document.getElementById("sprite-model-container"));
    switcher.addEventListener("pointerenter", () => setCharacterHoverState(true), listenerOptions);
    switcher.addEventListener("pointerleave", () => setCharacterHoverState(false), listenerOptions);
    switchAction?.addEventListener(
      "click",
      () => setOpen(true),
      listenerOptions,
    );
    sleepAction?.addEventListener(
      "click",
      () => setCharacterSleeping(!characterSleeping),
      listenerOptions,
    );
    wakeAction?.addEventListener(
      "click",
      () => setCharacterSleeping(false),
      listenerOptions,
    );
    options.forEach((option) => {
      option.addEventListener(
        "click",
        () => {
          selectCharacterModel(option.dataset.characterModelOption);
          setOpen(false);
        },
        listenerOptions,
      );
    });
    backdrop.addEventListener("click", () => setOpen(false), listenerOptions);
    document.addEventListener(
      "click",
      (event) => {
        if (!suppressCharacterClick) return;
        const runtime = getActiveCharacterRuntime();
        if (runtime?.contains(event.target)) {
          event.preventDefault();
          event.stopImmediatePropagation();
        }
      },
      { signal: controller.signal, capture: true },
    );
    document.addEventListener(
      "keydown",
      (event) => {
        if (event.key === "Escape") {
          setOpen(false);
          return;
        }
        if (
          !optionsPanel.hidden &&
          ["ArrowDown", "ArrowUp", "Home", "End"].includes(event.key)
        ) {
          event.preventDefault();
          const currentIndex = options.indexOf(document.activeElement);
          const nextIndex = event.key === "Home"
            ? 0
            : event.key === "End"
              ? options.length - 1
              : event.key === "ArrowUp"
                ? (currentIndex <= 0 ? options.length - 1 : currentIndex - 1)
                : (currentIndex + 1) % options.length;
          options[nextIndex]?.focus({ preventScroll: true });
        }
      },
      listenerOptions,
    );
    const preventBackgroundScroll = (event) => {
      if (optionsPanel.hidden) return;
      if (optionsPanel.contains(event.target)) return;
      event.preventDefault();
      event.stopPropagation();
    };
    document.addEventListener("wheel", preventBackgroundScroll, {
      signal: controller.signal,
      capture: true,
      passive: false,
    });
    document.addEventListener("touchmove", preventBackgroundScroll, {
      signal: controller.signal,
      capture: true,
      passive: false,
    });
    window.addEventListener("scroll", restoreLockedScroll, listenerOptions);
    window.addEventListener(
      "firefly:character-model-change",
      (event) => {
        updateCharacterModelUI(event.detail?.model || getSelectedCharacterModel());
        updateResponsiveDisplay();
        if (event.detail?.model === "firefly") initSpineModel();
        requestAnimationFrame(() => {
          attachCharacterRuntime(getActiveCharacterRuntime());
          applyCharacterPosition(characterPosition);
        });
      },
      listenerOptions,
    );
    window.addEventListener(
      "firefly:character-runtime-ready",
      (event) => {
        attachCharacterRuntime(event.detail?.runtime);
        setCharacterSleeping(characterSleeping, false);
      },
      listenerOptions,
    );
    window.addEventListener(
      "resize",
      () => applyCharacterPosition(characterPosition, true),
      listenerOptions,
    );

    setOpen(false);
    selectCharacterModel(getSelectedCharacterModel(), false);
    updateCharacterSleepUI();
    applyCharacterPosition(characterPosition);
    window.__fireflyCharacterPositionManager = {
      attachRuntime: attachCharacterRuntime,
      apply: applyCharacterPosition,
      layout: layoutCharacterControls,
    };
  }

  // 动态加载 Spine CSS（带本地备用）
  function loadSpineCSS() {
    if (!spineModelConfig.enable) return;

    // 检查是否已经加载
    const existingLink = document.querySelector('link[href*="spine-player"]');
    if (existingLink) return;

    // 首先尝试加载 CDN CSS
    const cdnLink = document.createElement("link");
    cdnLink.rel = "stylesheet";
    cdnLink.href =
      "https://unpkg.com/@esotericsoftware/spine-player@4.2.*/dist/spine-player.min.css";

    // 监听加载失败事件，自动回退到本地文件
    cdnLink.onerror = function () {
      console.warn("⚠️ Spine CSS CDN failed, trying local fallback...");

      // 移除失败的 CDN link
      if (cdnLink.parentNode) {
        cdnLink.parentNode.removeChild(cdnLink);
      }

      // 创建本地备用 CSS link
      const localLink = document.createElement("link");
      localLink.rel = "stylesheet";
      localLink.href = cssPath;
      localLink.onerror = function () {
        console.error("❌ Failed to load Spine CSS");
      };

      document.head.appendChild(localLink);
    };

    document.head.appendChild(cdnLink);
  }

  // 消息框功能已移至公共组件 MessageBox.astro
  let isClickProcessing = false; // 防止重复点击的标志
  let lastClickTime = 0; // 记录最后一次点击时间

  // 全局变量，防止重复初始化
  window.spineModelInitialized = window.spineModelInitialized || false;
  window.spinePlayerInstance = window.spinePlayerInstance || null;

  // 消息显示函数 - 使用公共消息框组件
  function showMessage(message) {
    // 使用公共消息框组件
    if (window.showModelMessage) {
      window.showModelMessage(message, {
        containerId: "spine-model-container",
        displayTime: spineModelConfig.interactive.messageDisplayTime || 3000
      });
    }
  }

  // 更新响应式显示
  function updateResponsiveDisplay() {
    if (!spineModelConfig.enable) return;

    const container = document.getElementById("spine-model-container");
    const spriteContainer = document.getElementById("sprite-model-container");
    const switcher = document.querySelector("[data-character-model-switcher]");
    const isMobile =
      spineModelConfig.responsive.hideOnMobile &&
      window.innerWidth <= spineModelConfig.responsive.mobileBreakpoint;
    if (switcher) switcher.style.display = isMobile ? "none" : "block";
    if (!container && !spriteContainer) return;

    // 检查移动端显示设置
    const modelType = CHARACTER_MODEL_TYPES[getSelectedCharacterModel()];
    if (container) {
      container.style.display = isMobile || modelType !== "spine" ? "none" : "block";
    }
    if (spriteContainer) {
      spriteContainer.style.display = isMobile || modelType !== "sprite" ? "none" : "block";
    }
    layoutCharacterControls();
  }

  // 清理函数
  function cleanupSpineModel() {
    console.log("🧹 Cleaning up existing Spine model...");

    // 清理消息显示（使用公共组件）
    if (window.clearModelMessage) {
      window.clearModelMessage();
    }

    // 清理现有的播放器实例
    if (window.spinePlayerInstance) {
      try {
        if (window.spinePlayerInstance.dispose) {
          window.spinePlayerInstance.dispose();
        }
      } catch (e) {
        console.warn("Error disposing spine player:", e);
      }
      window.spinePlayerInstance = null;
    }

    // 清理容器内容
    const playerContainer = document.getElementById("spine-player-container");
    if (playerContainer) {
      playerContainer.innerHTML = "";
    }

    // 重置初始化标志
    window.spineModelInitialized = false;
  }

  async function initSpineModel() {
    if (!spineModelConfig.enable) return;
    if (getSelectedCharacterModel() !== "firefly") {
      updateResponsiveDisplay();
      return;
    }

    // 检查移动端显示设置，如果隐藏则不加载运行时
    if (
      spineModelConfig.responsive.hideOnMobile &&
      window.innerWidth <= spineModelConfig.responsive.mobileBreakpoint
    ) {
      console.log("📱 Mobile device detected, skipping Spine model initialization");
      const container = document.getElementById("spine-model-container");
      if (container) container.style.display = "none";
      return;
    }

    // 检查是否已经初始化
    if (window.spineModelInitialized) {
      console.log("⏭️ Spine model already initialized, skipping...");
      return;
    }

    console.log("🎯 Initializing Spine Model...");

    // 先清理可能存在的旧实例
    cleanupSpineModel();

    // 首先加载 CSS
    loadSpineCSS();

    // 加载 Spine Web Player 运行时
    const loadSpineRuntime = () => {
      return new Promise((resolve, reject) => {
        if (typeof window.spine !== "undefined") {
          console.log("✅ Spine runtime already loaded");
          resolve();
          return;
        }

        console.log("📦 Loading Spine runtime...");
        const script = document.createElement("script");
        script.src =
          "https://unpkg.com/@esotericsoftware/spine-player@4.2.*/dist/iife/spine-player.min.js";
        script.onload = () => {
          console.log("✅ Spine runtime loaded from CDN");
          resolve();
        };
        script.onerror = (_error) => {
          console.warn("⚠️ CDN failed, trying local fallback...");

          // 尝试本地回退
          const fallbackScript = document.createElement("script");
          fallbackScript.src = jsPath;
          fallbackScript.onload = () => {
            console.log("✅ Spine runtime loaded from local fallback");
            resolve();
          };
          fallbackScript.onerror = () => {
            reject(new Error("Failed to load Spine runtime"));
          };
          document.head.appendChild(fallbackScript);
        };
        document.head.appendChild(script);
      });
    };

    // 等待 Spine 库加载
    const waitForSpine = () => {
      return new Promise((resolve, reject) => {
        let attempts = 0;
        const maxAttempts = 50;

        const check = () => {
          attempts++;
          if (typeof window.spine !== "undefined" && window.spine.SpinePlayer) {
            console.log("✅ Spine runtime loaded");
            resolve();
          } else if (attempts >= maxAttempts) {
            reject(new Error("Spine runtime loading timeout"));
          } else {
            setTimeout(check, 100);
          }
        };
        check();
      });
    };

    try {
      // 首先加载 Spine 运行时
      await loadSpineRuntime();

      // 然后等待 Spine 对象可用
      await waitForSpine();

      // 标记为已初始化
      window.spineModelInitialized = true;

      // 创建 SpinePlayer
      new window.spine.SpinePlayer("spine-player-container", {
        skeleton: modelPath,
        atlas: atlasPath,
        animation: "idle",
        backgroundColor: "#00000000", // 透明背景
        showControls: false, // 隐藏控件
        alpha: true,
        premultipliedAlpha: false,
        success: (player) => {
          console.log("🎉 Spine model loaded successfully!");

          // 保存播放器实例引用
          window.spinePlayerInstance = player;

          // 构建可用动画索引，避免播放不存在的动画导致报错
          const availableAnimations = new Set(
            (player.skeleton?.data?.animations || [])
              .map((anim) => anim?.name)
              .filter(Boolean)
          );

          const pickRandom = (list) =>
            list[Math.floor(Math.random() * list.length)];

          const configuredClickAnims =
            spineModelConfig.interactive.clickAnimations ||
            (spineModelConfig.interactive.clickAnimation
              ? [spineModelConfig.interactive.clickAnimation]
              : []);

          const configuredIdleAnims =
            spineModelConfig.interactive.idleAnimations || ["idle"];

          const validClickAnims = configuredClickAnims.filter((name) =>
            availableAnimations.has(name)
          );
          const validIdleAnims = configuredIdleAnims.filter((name) =>
            availableAnimations.has(name)
          );

          const fallbackIdleAnim =
            (availableAnimations.has("idle") && "idle") ||
            validIdleAnims[0] ||
            configuredIdleAnims[0] ||
            configuredClickAnims[0] ||
            Array.from(availableAnimations)[0];

          const safeSetAnimation = (name, loop) => {
            if (!name || !availableAnimations.has(name)) {
              return false;
            }
            try {
              player.setAnimation(name, loop);
              return true;
            } catch (e) {
              console.warn(`Failed to play animation: ${name}`, e);
              return false;
            }
          };

          const runSpineInteraction = () => {
            if (characterSleeping) return;
            const currentTime = Date.now();
            if (isClickProcessing || currentTime - lastClickTime < 500) return;

            isClickProcessing = true;
            lastClickTime = currentTime;

            if (validClickAnims.length > 0) {
              const randomClickAnim = pickRandom(validClickAnims);
              safeSetAnimation(randomClickAnim, false);
              window.setTimeout(() => {
                if (characterSleeping) return;
                const randomIdle = validIdleAnims.length > 0
                  ? pickRandom(validIdleAnims)
                  : fallbackIdleAnim;
                safeSetAnimation(randomIdle, true);
              }, 2000);
            } else if (fallbackIdleAnim) {
              safeSetAnimation(fallbackIdleAnim, true);
            }

            const messages = spineModelConfig.interactive.clickMessages;
            if (messages?.length > 0) showMessage(pickRandom(messages));
            window.setTimeout(() => {
              isClickProcessing = false;
            }, 500);
          };
          window.__fireflySpineInteract = runSpineInteraction;

          // 初始动画兜底，防止默认 idle 不存在
          if (!safeSetAnimation("idle", true) && fallbackIdleAnim) {
            safeSetAnimation(fallbackIdleAnim, true);
          }

          // 输出一次配置校验信息，便于排查模型与配置不一致
          const missingClickAnims = configuredClickAnims.filter(
            (name) => !availableAnimations.has(name)
          );
          if (missingClickAnims.length > 0) {
            console.warn(
              "Spine click animations not found in model:",
              missingClickAnims
            );
          }

          // 初始化完成后设置默认姿态
          setTimeout(() => {
            if (player.skeleton) {
              try {
                player.skeleton.setToSetupPose();
                const physicsMode =
                  window.spine?.Physics?.update ??
                  window.spine?.Physics?.pose ??
                  window.spine?.Physics?.none ??
                  0;
                player.skeleton.updateWorldTransform(physicsMode);
              } catch (e) {
                console.warn("Error positioning skeleton:", e);
              }
            }
          }, 500);

          // 设置交互功能
          if (spineModelConfig.interactive.enabled) {
            const canvas = document.querySelector(
              "#spine-player-container canvas"
            );
            if (canvas) {
              canvas.addEventListener("click", runSpineInteraction);

              // 设置待机动画循环（仅在至少两个有效待机动画时启用）
              if (validIdleAnims.length > 1) {
                setInterval(() => {
                  const randomIdle = pickRandom(validIdleAnims);
                  safeSetAnimation(randomIdle, true);
                }, spineModelConfig.interactive.idleInterval);
              }
            }
          }

          console.log("✅ Spine model setup complete!");
        },
        error: (_player, reason) => {
          console.error("❌ Spine model loading error:", reason);

          const errorDiv = document.getElementById("spine-error");
          if (errorDiv) {
            errorDiv.style.display = "block";
            errorDiv.innerHTML = `
              <div style="color: #ff4444; padding: 20px; text-align: center; font-size: 14px;">
                <div>⚠️ Spine 模型加载失败</div>
                <div style="font-size: 12px; margin-top: 8px; color: #888;">${reason}</div>
              </div>
            `;
          }

          const canvas = document.getElementById("spine-canvas");
          if (canvas) canvas.style.display = "none";
        },
      });
    } catch (error) {
      console.error("Spine model initialization error:", error);

      // 重置初始化标志，允许重试
      window.spineModelInitialized = false;

      const errorDiv = document.getElementById("spine-error");
      if (errorDiv) {
        errorDiv.style.display = "block";
        errorDiv.innerHTML = `
          <div style="color: #ff4444; padding: 20px; text-align: center; font-size: 14px;">
            <div>⚠️ Spine 运行时加载失败</div>
            <div style="font-size: 12px; margin-top: 8px; color: #888;">${error instanceof Error ? error.message : "未知错误"}</div>
          </div>
        `;
      }
    }
  }

  // 监听页面卸载事件，清理资源
  window.addEventListener("beforeunload", cleanupSpineModel);

  // 监听 Swup 页面切换事件（如果使用了 Swup）
  if (typeof window.swup !== "undefined" && window.swup.hooks) {
    window.swup.hooks.on("content:replace", () => {
      // 只更新响应式显示，不重新创建模型
      setTimeout(() => {
        updateResponsiveDisplay();
      }, 100);
    });
  }

  // 监听 popstate 事件（浏览器前进后退）
  window.addEventListener("popstate", () => {
    setTimeout(() => {
      updateResponsiveDisplay();
    }, 100);
  });

  // 监听窗口大小变化
  window.addEventListener("resize", updateResponsiveDisplay);

  // 页面加载完成后初始化（只初始化一次）
  initCharacterModelSwitcher();
  updateResponsiveDisplay();
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSpineModel);
  } else {
    initSpineModel();
  }
</script>

